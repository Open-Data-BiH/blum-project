---
// Leaflet CSS is loaded here so it's scoped to pages that use this component.
// The JS is loaded client-side in the script block at the end of this component.
import 'leaflet/dist/leaflet.css';
import '../styles/pages/_map-legend.scss';
import MapContainer from './map/MapContainer.astro';

interface Props {
  locale: 'bhs' | 'en';
}

const { locale } = Astro.props;
const isEnglish = locale === 'en';
---

<div class="airport-transfer-info">
  <div class="airport-transfer-details">
    <div class="airport-info-block airport-info-block--price">
      <div class="airport-info-block__icon" aria-hidden="true">
        <i class="fa-solid fa-credit-card"></i>
      </div>
      <div class="airport-info-block__content">
        <p class="airport-info-block__label">
          {isEnglish ? 'Price' : 'Cijena'}
        </p>
        <p id="airport-price" class="airport-info-block__value">
          {isEnglish ? 'One-way ticket price is 10.00 KM' : 'Cijena karte u jednom pravcu iznosi 10,00 KM'}
        </p>
      </div>
    </div>

    <div class="airport-info-block airport-info-block--departure">
      <div class="airport-info-block__icon" aria-hidden="true">
        <i class="fa-solid fa-location-dot"></i>
      </div>
      <div class="airport-info-block__content">
        <p class="airport-info-block__label">
          {isEnglish ? 'Departure point' : 'Polazište'}
        </p>
        <p id="airport-departure-location" class="airport-info-block__value">
          {isEnglish
            ? 'All departures are from the Old Bus Station (Vidovdanska street) and the Main (New) Bus Station.'
            : 'Svi polasci su sa Stare autobuske stanice (Vidovdanska ulica) i Glavne (Nove) autobuske stanice.'}
        </p>
      </div>
    </div>

    <p id="airport-more-info">
      {isEnglish ? 'For more information about departures, visit the ' : 'Za više informacija o polascima posjetite '}
      <a href="https://smiljiccompany.ba/avio-transferi/" target="_blank" rel="noopener noreferrer">
        {isEnglish ? "operator's website" : 'internet stranicu prevoznika'}
      </a>
      .
    </p>
  </div>

  <MapContainer mapId="airport-map" label="Airport and shuttle stops map" className="small-map">
    <p class="airport-map-caption">{isEnglish ? 'Airport and shuttle bus stops' : 'Aerodrom i stajališta shuttle autobusa'}</p>
  </MapContainer>
</div>

<script>
  const airportMapEl = document.getElementById('airport-map');
  if (airportMapEl) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          import('../scripts/features/airport/airport-map').then(({ initAirportMap }) => {
            initAirportMap();
          });
        }
      },
      { rootMargin: '300px' },
    );
    observer.observe(airportMapEl);
  }
</script>
