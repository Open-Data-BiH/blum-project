---
import { getPagePath, type Locale } from '../lib/site-config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl}${path.replace(/^\/+/, '')}`;
const privacyHref = withBase(getPagePath('privacy', locale));
const isEnglish = locale === 'en';
---

<div class="cookie-consent" id="cookie-consent" role="dialog" aria-label="Cookie consent" hidden>
  <div class="cookie-consent__body">
    <p class="cookie-consent__text">
      {isEnglish
        ? 'This website uses anonymous analytics to understand how the site is used and improve the user experience. No personal data is collected.'
        : 'Ova stranica koristi anonimnu analitiku kako bismo razumjeli kako se sajt koristi i poboljšali korisničko iskustvo. Lični podaci se ne prikupljaju.'}
      <a href={privacyHref} class="cookie-consent__link">
        {isEnglish ? 'Privacy Policy' : 'Politika privatnosti'}
      </a>
    </p>
    <div class="cookie-consent__actions">
      <button class="cookie-consent__btn cookie-consent__btn--accept" id="cookie-accept">
        {isEnglish ? 'Accept' : 'Prihvati'}
      </button>
      <button class="cookie-consent__btn cookie-consent__btn--decline" id="cookie-decline">
        {isEnglish ? 'Decline' : 'Odbij'}
      </button>
    </div>
  </div>
</div>

<script>
  import { initCookieConsent } from '../scripts/features/layout/cookie-consent';
  initCookieConsent();
</script>
