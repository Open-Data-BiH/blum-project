---
import '../styles/pages/_faq.scss';
import faqData from '../../public/data/transport/faq.json';

interface Question {
  id: string;
  question: { bhs: string; en: string };
  answer: { bhs: string; en: string };
}

interface Category {
  id: string;
  title: { bhs: string; en: string };
  questions: Question[];
}

interface Props {
  locale: 'bhs' | 'en';
}

const { categories } = faqData as { categories: Category[] };
const { locale } = Astro.props;
---

<div class="faq-container" id="faq-content">
  <div class="faq-categories">
    {categories.map((category) => (
      <div class="faq-category" data-category-id={category.id}>
        <h3 class="faq-category__title">{category.title[locale]}</h3>
        <div class="faq-questions">
          {category.questions.map((q) => (
            <div class="faq-item" data-question-id={q.id} data-category-id={category.id}>
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls={`answer-${q.id}`}
              >
                <span class="faq-question__text">{q.question[locale]}</span>
                <i class="faq-question__icon fas fa-chevron-down" aria-hidden="true"></i>
              </button>
              <div class="faq-answer" id={`answer-${q.id}`} aria-hidden="true">
                <div class="faq-answer__content">
                  <p>{q.answer[locale]}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  const faqEl = document.getElementById('faq-content');
  if (faqEl) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          import('../scripts/features/faq/faq-accordion').then(({ initFAQAccordion }) => {
            initFAQAccordion();
          });
        }
      },
      { rootMargin: '300px' },
    );
    observer.observe(faqEl);
  }
</script>
