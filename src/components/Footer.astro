---
const year = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl}${path.replace(/^\/+/, '')}`;
---

<footer class="footer">
  <div class="footer__main">
    <div class="footer__description">
      <p id="footer-mission-text">
        BL Prevoz je nezavisna platforma za informacije o javnom prevozu u Banjoj Luci.
      </p>
    </div>

    <nav class="footer__nav" aria-label="Footer links">
      <span class="footer__nav-heading" id="footer-nav-heading">Informacije</span>
      <a href={withBase('faq/')} id="footer-link-faq">FAQ</a>
      <a href={withBase('about/')} id="footer-link-about">O projektu</a>
      <a href={withBase('contact/')} id="footer-link-contact">Kontakt</a>
      <a href={withBase('privacy/')} id="footer-link-privacy">Politika privatnosti</a>
    </nav>

    <div class="footer__action">
      <div class="footer__kofi" id="footer-kofi-container"></div>
    </div>
  </div>

  <div class="footer__bottom">
    <p>&copy; {year} BL Prevoz</p>
  </div>
</footer>

<script is:inline>
  // Defer Ko-fi widget until the footer enters the viewport to avoid
  // adding a third-party request chain to the critical path.
  (function() {
    var container = document.getElementById('footer-kofi-container');
    if (!container) return;
    var loaded = false;
    function loadKofi() {
      if (loaded) return;
      loaded = true;
      var script = document.createElement('script');
      script.src = 'https://storage.ko-fi.com/cdn/widget/Widget_2.js';
      script.onload = function() {
        var lang = localStorage.getItem('selectedLanguage') || 'bhs';
        var btnText = lang === 'en' ? 'Support this project' : 'Podržite ovaj projekat';
        if (typeof kofiwidget2 !== 'undefined') {
          kofiwidget2.init(btnText, '#1a4d73', 'J3J11VR53R');
          container.innerHTML = kofiwidget2.getHTML();
        }
      };
      document.body.appendChild(script);
    }
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function(entries, observer) {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          loadKofi();
        }
      }, { rootMargin: '200px' }).observe(container);
    } else {
      // Fallback: load after page is idle
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadKofi);
      } else {
        window.addEventListener('load', loadKofi);
      }
    }
  })();
</script>
