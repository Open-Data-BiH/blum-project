---
const year = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl}${path.replace(/^\/+/, '')}`;
---

<footer class="footer">
  <div class="footer__main">
    <div class="footer__description">
      <p id="footer-mission-text">
        BL Prevoz je nezavisna platforma za informacije o javnom prevozu u Banjoj Luci.
      </p>
    </div>

    <nav class="footer__nav" aria-label="Footer links">
      <span class="footer__nav-heading" id="footer-nav-heading">Informacije</span>
      <a href={withBase('faq/')} id="footer-link-faq">FAQ</a>
      <a href={withBase('about/')} id="footer-link-about">O projektu</a>
      <a href={withBase('contact/')} id="footer-link-contact">Kontakt</a>
      <a href={withBase('privacy/')} id="footer-link-privacy">Politika privatnosti</a>
    </nav>

    <div class="footer__action">
      <div class="footer__kofi" id="footer-kofi-container"></div>
    </div>
  </div>

  <div class="footer__bottom">
    <p>&copy; {year} BL Prevoz</p>
  </div>
</footer>

<script>
  import { initFooterKofi } from '../scripts/features/layout/footer-kofi';
  initFooterKofi();
</script>
