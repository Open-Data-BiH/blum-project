---
const year = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl}${path.replace(/^\/+/, '')}`;
---

<footer class="footer">
  <div class="footer__top">
    <div class="footer__mission">
      <p id="footer-mission-text">
        BLum je nezavisna platforma za bolju dostupnost informacija o javnom prevozu u Banjoj Luci.
      </p>
    </div>

    <nav class="footer__links" aria-label="Footer links">
      <a href={withBase('faq/')} id="footer-link-faq">FAQ</a>
      <span class="footer__separator" aria-hidden="true">&middot;</span>
      <a href={withBase('about/')} id="footer-link-about">O projektu</a>
      <span class="footer__separator" aria-hidden="true">&middot;</span>
      <a href={withBase('contact/')} id="footer-link-contact">Kontakt</a>
      <span class="footer__separator" aria-hidden="true">&middot;</span>
      <a href={withBase('privacy/')} id="footer-link-privacy">Privatnost</a>
    </nav>

    <div class="footer__kofi" id="footer-kofi-container"></div>
  </div>

  <div class="footer__bottom">
    <p>&copy; {year} BLum &middot; Urbana mobilnost Banja Luka</p>
  </div>
</footer>

<script is:inline>
  (function() {
    var script = document.createElement('script');
    script.src = 'https://storage.ko-fi.com/cdn/widget/Widget_2.js';
    script.onload = function() {
      var lang = localStorage.getItem('selectedLanguage') || 'bhs';
      var btnText = lang === 'en' ? 'Support this project' : 'Podržite ovaj projekat';
      var container = document.getElementById('footer-kofi-container');
      if (container && typeof kofiwidget2 !== 'undefined') {
        kofiwidget2.init(btnText, '#1a4d73', 'J3J11VR53R');
        container.innerHTML = kofiwidget2.getHTML();
      }
    };
    document.head.appendChild(script);
  })();
</script>
