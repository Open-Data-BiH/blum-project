---
import { getPagePath, type Locale } from '../lib/site-config';
import '../styles/pages/_updates.scss';
import updatesData from '../../public/data/transport/updates.json';
import type { Category, Update } from '../types/updates';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const { categories, updates } = updatesData as { categories: Category[]; updates: Update[] };

const activeUpdates = updates
  .filter((u) => u.isActive)
  .sort((a, b) => new Date(b.datePublished).getTime() - new Date(a.datePublished).getTime())
  .slice(0, 3);

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl}${path.replace(/^\/+/, '')}`;
const updatesBasePath = getPagePath('updates', locale);
const isEnglish = locale === 'en';
---

<section class="section section--narrow" id="home-updates">
  <div class="container">
    <h2 class="section__title" id="home-updates-title">{isEnglish ? 'Updates' : 'Obavjestenja'}</h2>

    {activeUpdates.length === 0 ? (
      <div class="home-updates-empty">
        <i class="fas fa-check-circle" aria-hidden="true"></i>
        <p>{isEnglish ? 'No active updates. Public transport is operating normally.' : 'Nema aktivnih obavještenja. Javni prevoz saobraća redovno.'}</p>
      </div>
    ) : (
      <div class="home-updates-list">
        {activeUpdates.map((update) => {
          const cat = categories.find((c) => c.id === update.type);
          const catIcon = cat ? cat.icon : 'fa-info-circle';
          const updateHref = `${withBase(updatesBasePath)}#update-${encodeURIComponent(update.id)}`;
          return (
            <a href={updateHref} class="home-update-card-link">
              <article class={`home-update-card home-update-card--${update.severity}`}>
                <div class="home-update-card__header">
                  <span class={`update-badge update-badge--${update.type}`}>
                    <i class={`fas ${catIcon}`} aria-hidden="true"></i>
                    {cat && cat.label[locale]}
                  </span>
                  <span class="home-update-card__date">
                    {new Date(update.datePublished).toLocaleDateString(locale === 'en' ? 'en-BA' : 'bs-BA', { day: '2-digit', month: '2-digit', year: 'numeric' })}
                  </span>
                </div>
                <h3 class="home-update-card__title">{update.title[locale]}</h3>
                <p class="home-update-card__description">{update.description[locale]}</p>
              </article>
            </a>
          );
        })}
      </div>
    )}

    <div class="home-updates-cta">
      <a href={withBase(updatesBasePath)} class="btn btn--sm">
        <i class="fas fa-bell" aria-hidden="true"></i>
        {isEnglish ? 'All updates' : 'Sva obavještenja'}
      </a>
    </div>
  </div>
</section>
