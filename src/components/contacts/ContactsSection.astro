---
import contactsData from '../../../public/data/transport/contacts.json';
import translationsData from '../../../public/data/config/bhs_en_translations.json';
import type { Locale } from '../../lib/site-config';
import type { ContactsFile, Contact } from '../../types/contacts';

interface Translations {
  bhs: {
    sections: { contact: { phone?: string; email?: string } };
    ui: { visit?: string };
  };
  en: {
    sections: { contact: { phone?: string; email?: string } };
    ui: { visit?: string };
  };
}

const { contacts } = contactsData as ContactsFile;
const translations = translationsData as Translations;

interface Props {
  locale?: Locale;
}

const { locale = 'bhs' } = Astro.props;

const labels = {
  bhs: {
    phone: translations.bhs.sections.contact.phone ?? 'Telefon:',
    email: translations.bhs.sections.contact.email ?? 'Email:',
    visit: translations.bhs.ui.visit ?? 'Posjetite web stranicu',
  },
  en: {
    phone: translations.en.sections.contact.phone ?? 'Phone:',
    email: translations.en.sections.contact.email ?? 'Email:',
    visit: translations.en.ui.visit ?? 'Visit website',
  },
};

const formatTelHref = (phone?: string | null): string =>
  phone ? phone.replace(/[^+\d]/g, '') : '';

const isAuthorityType = (contact: Contact): boolean =>
  contact.type.bhs === 'Gradska uprava' || contact.type.en === 'City Administration';

const authorityContacts = contacts.filter(isAuthorityType);
const operatorContacts = contacts.filter((contact) => !isAuthorityType(contact));
const activeLabels = labels[locale];
---

<section class="section section--narrow" id="contact">
  <div class="container">
    <h2 class="section__title" id="contact-title">{locale === 'en' ? 'Useful contacts' : 'Korisni kontakti'}</h2>

    <div class="contact-group contact-group--primary">
      <h3 class="contact-group__title" id="contact-group-authorities-title">{locale === 'en' ? 'City services' : 'Gradske sluzbe'}</h3>
      <div class="contact-cards">
        {authorityContacts.map((contact) => (
          <div
            class="contact-card contact-card--authority"
            id={`contact-${contact.id}`}
            style={contact.color ? `--contact-accent:${contact.color};` : undefined}
          >
            <div class="contact-card__top">
              <p class="contact-type">{contact.type[locale]}</p>
              <h3 class="contact-name">{contact.name[locale]}</h3>
              <p class="contact-department">{contact.department[locale]}</p>
            </div>

            <div class="contact-details">
              {contact.phoneDisplay && (
                <a
                  class="contact-detail"
                  href={`tel:${formatTelHref(contact.phoneDisplay)}`}
                  aria-label={`${activeLabels.phone} ${contact.phoneDisplay}`}
                >
                  <i class="fas fa-phone" aria-hidden="true"></i>
                  <span class="contact-detail__value">{contact.phoneDisplay}</span>
                </a>
              )}

              {contact.email && (
                <a
                  class="contact-detail"
                  href={`mailto:${contact.email}`}
                  aria-label={`${activeLabels.email} ${contact.email}`}
                >
                  <i class="fas fa-envelope" aria-hidden="true"></i>
                  <span class="contact-detail__value">{contact.email}</span>
                </a>
              )}
            </div>

            <div class="contact-card__footer">
              {contact.website ? (
                <a class="contact-website" href={contact.website} target="_blank" rel="noopener noreferrer">
                  {activeLabels.visit}
                  <i class="fas fa-external-link-alt" aria-hidden="true"></i>
                </a>
              ) : (
                <span class="contact-website contact-website--empty" aria-hidden="true"></span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="contact-group">
      <h3 class="contact-group__title" id="contact-group-operators-title">{locale === 'en' ? 'Operators' : 'Prevoznici'}</h3>
      <div class="contact-cards">
        {operatorContacts.map((contact) => (
          <div
            class="contact-card contact-card--operator"
            id={`contact-${contact.id}`}
            style={contact.color ? `--contact-accent:${contact.color};` : undefined}
          >
            <div class="contact-card__top">
              <p class="contact-type">{contact.type[locale]}</p>
              <h3 class="contact-name">{contact.name[locale]}</h3>
              <p class="contact-department">{contact.department[locale]}</p>
            </div>

            <div class="contact-details">
              {contact.phoneDisplay && (
                <a
                  class="contact-detail"
                  href={`tel:${formatTelHref(contact.phoneDisplay)}`}
                  aria-label={`${activeLabels.phone} ${contact.phoneDisplay}`}
                >
                  <i class="fas fa-phone" aria-hidden="true"></i>
                  <span class="contact-detail__value">{contact.phoneDisplay}</span>
                </a>
              )}

              {contact.email && (
                <a
                  class="contact-detail"
                  href={`mailto:${contact.email}`}
                  aria-label={`${activeLabels.email} ${contact.email}`}
                >
                  <i class="fas fa-envelope" aria-hidden="true"></i>
                  <span class="contact-detail__value">{contact.email}</span>
                </a>
              )}
            </div>

            <div class="contact-card__footer">
              {contact.website ? (
                <a class="contact-website" href={contact.website} target="_blank" rel="noopener noreferrer">
                  {activeLabels.visit}
                  <i class="fas fa-external-link-alt" aria-hidden="true"></i>
                </a>
              ) : (
                <span class="contact-website contact-website--empty" aria-hidden="true"></span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
