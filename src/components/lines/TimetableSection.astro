---
/**
 * TimetableSection — structural shell only.
 * All data loading and rendering happens client-side via timetable.ts.
 */
import '../../styles/pages/_timetables.scss';
import type { Locale } from '../../lib/site-config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="section section--wide" id="timetable">
  <div class="container">
    <h2 class="section__title" id="lines-timetable-title">{locale === 'en' ? 'Timetable' : 'Red voznje'}</h2>
    <div class="line-selector-wrapper">
      <label for="line-select" class="visually-hidden">{locale === 'en' ? 'Select a line' : 'Izaberite liniju'}</label>
      <select id="line-select" aria-label={locale === 'en' ? 'Select a line' : 'Izaberite liniju'}></select>
    </div>
    <div id="timetable-display"></div>
  </div>
</section>

<script>
  const timetableEl = document.getElementById('timetable');
  if (timetableEl) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          import('../../scripts/features/lines/timetable').then(({ setupTimetableSelection }) => {
            setupTimetableSelection();
          });
        }
      },
      { rootMargin: '400px' },
    );
    observer.observe(timetableEl);
  }
</script>
