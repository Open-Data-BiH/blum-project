---
/**
 * UrbanLinesViewer — shell div for the Leaflet CRS.Simple image viewer.
 * The map is initialised client-side by urban-lines-viewer.ts.
 */
import 'leaflet/dist/leaflet.css';
import MapContainer from '../map/MapContainer.astro';
---

<MapContainer mapId="urban-lines-viewer" className="urban-lines-map" />

<script>
  const viewerEl = document.getElementById('urban-lines-viewer');
  if (viewerEl) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          import('../../scripts/urban-lines-viewer').then(({ initUrbanLinesViewer }) => {
            initUrbanLinesViewer();
          });
        }
      },
      { rootMargin: '400px' },
    );
    observer.observe(viewerEl);
  }
</script>
