---
// Homepage interactive map container
// Loads Leaflet styles via ESM import to avoid CDN dependency
import 'leaflet/dist/leaflet.css';
import '../../styles/pages/_map-legend.scss';
import MapContainer from './MapContainer.astro';
import MapNote from './MapNote.astro';
---

<section class="section section--wide" id="map">
  <div class="container">
    <h2 class="section__title" id="map-title">Interaktivna mapa prevoza</h2>

    <MapContainer
      mapId="map-container"
      label="Interaktivna mapa prevoza"
      role="application"
      live="polite"
    >
      <noscript class="map-note">
        <i class="map-note__icon fas fa-info-circle" aria-hidden="true"></i>
        <div class="map-note__content">
          <p>
            JavaScript je potreban za prikaz interaktivne mape. Omogućite JavaScript u pregledaču kako biste vidjeli
            stajališta i linije.
          </p>
        </div>
      </noscript>
    </MapContainer>

    <MapNote id="bus-stops-note" className="map-note--info" showIcon={false}>
      <h3 class="map-note__title" id="map-note-title">O interaktivnoj mapi</h3>
      <p class="map-note__description" id="map-note-description">
        Markeri na mapi prikazuju ključne tačke javnog prevoza i druge važne lokacije u gradu, uključujući autobuska
        stajališta, glavnu autobusku stanicu, željezničke stanice, Nextbike stanice i aerodromski transfer. Novi
        sadržaji i lokacije biće postepeno dodavani.
      </p>
      <div class="map-note__tips" aria-labelledby="map-note-tips-title">
        <p class="map-note__tips-title" id="map-note-tips-title">Savjeti:</p>
        <ul class="map-note__tips-list">
          <li id="map-note-tip-item-1">Kliknite na marker da vidite približno vrijeme hodanja (radijus ~5 min).</li>
          <li id="map-note-tip-item-2">
            Korištenjem kontrola za slojeve možete uključiti ili isključiti pojedine vrste lokacija na mapi.
          </li>
        </ul>
      </div>
    </MapNote>
  </div>
</section>

<script>
  const mapSection = document.getElementById('map');
  if (mapSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          import('../../scripts/features/map/main-map').then(({ initMainMap }) => {
            initMainMap();
          });
        }
      },
      { rootMargin: '300px' },
    );
    observer.observe(mapSection);
  }
</script>
