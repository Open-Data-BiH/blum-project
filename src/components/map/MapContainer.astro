---
import { getLocaleFromPath } from '../../lib/site-config';

export interface Props {
  mapId: string;
  label?: string;
  className?: string;
  role?: astroHTML.JSX.AriaRole;
  live?: 'polite' | 'assertive' | 'off';
}

const { mapId, label, className, role, live } = Astro.props;
const liveAttr = live && live !== 'off' ? live : undefined;
const isEnglish = getLocaleFromPath(Astro.url.pathname) === 'en';
const loadingLabel = isEnglish ? 'Loading map…' : 'Učitavanje mape…';
---

<div class:list={['map-container', className]} aria-live={liveAttr}>
  <div id={mapId} aria-label={label} role={role}>
    <div class="map-loading" aria-hidden="true">
      <i class="fas fa-spinner fa-spin" aria-hidden="true"></i>
      <span class="map-loading__text">{loadingLabel}</span>
    </div>
  </div>
  <slot />
</div>
