---
import BaseLayout from '../layouts/BaseLayout.astro';
import AirportMap from '../components/AirportMap.astro';
---

<BaseLayout
  pageKey="airport"
  title="Prevoz do aerodroma Banja Luka – Cijene i polasci"
  description="Kako doći do Aerodroma Banja Luka. Cijene transfera, stajališta, polasci i mapa rute aerodromskog prevoza."
  canonicalUrl="https://blprevoz.com/airport/"
>
  <section class="section section--wide" id="airport">
    <div class="container">
      <h2 class="section__title" id="airport-title">
        <span data-lang="bhs">Aerodromski prevoz</span>
        <span data-lang="en" style="display:none">Airport Transport</span>
      </h2>
      <AirportMap />
    </div>
  </section>
</BaseLayout>
