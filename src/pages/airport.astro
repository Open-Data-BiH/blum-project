---
import BaseLayout from '../layouts/BaseLayout.astro';
import AirportMap from '../components/AirportMap.astro';

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl}${path.replace(/^\/+/, '')}`;
---

<BaseLayout
  pageKey="airport"
  title="Prevoz do aerodroma Banja Luka – Autobus, taksi, cijene | BNX"
  description="Kako doći do Aerodroma Banja Luka (BNX). Shuttle autobus 10 KM, 23 km od centra, 25–45 min vožnje. Cijene transfera, polasci, taksi alternative, parking i mapa."
  canonicalUrl="https://blprevoz.com/airport/"
>
  <!-- Airport Overview -->
  <section class="section" id="airport-overview">
    <div class="container">
      <h1 class="section__title" id="airport-title">
        <span data-lang="bhs">Prevoz do Aerodroma Banja Luka</span>
        <span data-lang="en" style="display:none">Getting to Banja Luka Airport</span>
      </h1>
      <p class="airport-intro" id="airport-intro">
        <span data-lang="bhs">
          Međunarodni aerodrom Banja Luka (IATA: BNX) nalazi se u Mahovljanima, oko 25 km
          sjeverno od centra grada. Najbrži pristup je autoputem E661 (Banja Luka – Gradiška).
          Aerodrom je povezan sa gradom shuttle autobusom kompanije Smiljić, a dostupne su
          i taksi usluge. Ispod su sve informacije potrebne za planiranje vašeg dolaska ili odlaska.
        </span>
        <span data-lang="en" style="display:none">
          Banja Luka International Airport (IATA: BNX) is located in Mahovljani, approximately
          25 km north of the city center. The fastest access is via the E661 motorway (Banja Luka – Gradiška).
          The airport is connected to the city by Smiljić shuttle bus, and taxi services are
          also available. Below you'll find all the information you need to plan your arrival or departure.
        </span>
      </p>

      <!-- Fast Answer Block -->
      <div class="airport-fast-answer">
        <div class="airport-fast-answer__header">
          <i class="fa-solid fa-bolt" aria-hidden="true"></i>
          <h2>
            <span data-lang="bhs">Kako od aerodroma do centra grada?</span>
            <span data-lang="en" style="display:none">How to get from the airport to the city center?</span>
          </h2>
        </div>
        <div class="airport-fast-answer__options">
          <div class="airport-fast-answer__option">
            <i class="fa-solid fa-bus" aria-hidden="true"></i>
            <div>
              <strong>
                <span data-lang="bhs">Shuttle autobus</span>
                <span data-lang="en" style="display:none">Shuttle bus</span>
              </strong>
              <span>~10 KM · 30–45 min</span>
            </div>
          </div>
          <div class="airport-fast-answer__option">
            <i class="fa-solid fa-taxi" aria-hidden="true"></i>
            <div>
              <strong>
                <span data-lang="bhs">Taksi</span>
                <span data-lang="en" style="display:none">Taxi</span>
              </strong>
              <span>~40–60 KM · 30–35 min</span>
            </div>
          </div>
          <div class="airport-fast-answer__option">
            <i class="fa-solid fa-car" aria-hidden="true"></i>
            <div>
              <strong>
                <span data-lang="bhs">Rent-a-car</span>
                <span data-lang="en" style="display:none">Rent-a-car</span>
              </strong>
              <span>
                <span data-lang="bhs">Dostupno na aerodromu</span>
                <span data-lang="en" style="display:none">Available at the airport</span>
              </span>
            </div>
          </div>
        </div>
        <p class="airport-fast-answer__note">
          <span data-lang="bhs">Udaljenost od aerodroma do centra: <strong>~25 km</strong> (autoput E661, petlja Mahovljani)</span>
          <span data-lang="en" style="display:none">Distance from airport to city center: <strong>~25 km</strong> (E661 motorway, Mahovljani interchange)</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Quick Facts -->
  <section class="section airport-quickfacts" id="airport-quickfacts">
    <div class="container">
      <h2 class="section__title airport-section-title">
        <span data-lang="bhs">Osnovne informacije</span>
        <span data-lang="en" style="display:none">Quick Facts</span>
      </h2>
      <div class="quickfacts-grid">
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-road"></i>
          </div>
          <div class="quickfact-card__label">
            <span data-lang="bhs">Udaljenost</span>
            <span data-lang="en" style="display:none">Distance</span>
          </div>
          <div class="quickfact-card__value">~25 km</div>
        </div>
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-clock"></i>
          </div>
          <div class="quickfact-card__label">
            <span data-lang="bhs">Vrijeme vožnje</span>
            <span data-lang="en" style="display:none">Travel time</span>
          </div>
          <div class="quickfact-card__value">30–45 min</div>
        </div>
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-money-bill-wave"></i>
          </div>
          <div class="quickfact-card__label">
            <span data-lang="bhs">Cijena autobusa</span>
            <span data-lang="en" style="display:none">Bus price</span>
          </div>
          <div class="quickfact-card__value">~10 KM</div>
        </div>
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-building"></i>
          </div>
          <div class="quickfact-card__label">
            <span data-lang="bhs">Prevoznik</span>
            <span data-lang="en" style="display:none">Operator</span>
          </div>
          <div class="quickfact-card__value">Smiljić</div>
        </div>
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-calendar-day"></i>
          </div>
          <div class="quickfact-card__label">
            <span data-lang="bhs">Učestalost</span>
            <span data-lang="en" style="display:none">Frequency</span>
          </div>
          <div class="quickfact-card__value">
            <span data-lang="bhs">Nekoliko polazaka dnevno</span>
            <span data-lang="en" style="display:none">Few departures per day</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FROM AIRPORT TO CITY -->
  <section class="section" id="airport-to-city">
    <div class="container">
      <div class="direction-heading">
        <div class="direction-heading__badge direction-heading__badge--arrival">
          <i class="fa-solid fa-plane-arrival" aria-hidden="true"></i>
          <span data-lang="bhs">Dolazak</span>
          <span data-lang="en" style="display:none">Arrival</span>
        </div>
        <h2 class="section__title airport-section-title">
          <span data-lang="bhs">Od aerodroma do grada</span>
          <span data-lang="en" style="display:none">From the airport to the city</span>
        </h2>
        <p class="direction-heading__subtitle">
          <span data-lang="bhs">Sletjeli ste na aerodrom BNX i trebate doći do centra Banje Luke.</span>
          <span data-lang="en" style="display:none">You've landed at BNX Airport and need to get to downtown Banja Luka.</span>
        </p>
      </div>

      <div class="transport-options-grid">
        <!-- Shuttle Bus — arrival -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-bus"></i>
            </div>
            <h3>
              <span data-lang="bhs">Shuttle autobus (Smiljić)</span>
              <span data-lang="en" style="display:none">Shuttle bus (Smiljić)</span>
            </h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span data-lang="bhs">Vrijeme vožnje: 30–45 min</span>
              <span data-lang="en" style="display:none">Travel time: 30–45 min</span>
            </li>
            <li>
              <i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i>
              <span data-lang="bhs">Cijena: ~10 KM (jedna vožnja)</span>
              <span data-lang="en" style="display:none">Price: ~10 KM (one way)</span>
            </li>
            <li>
              <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
              <span data-lang="bhs">Autobus čeka ispred terminala nakon dolaska leta</span>
              <span data-lang="en" style="display:none">Bus waits in front of the terminal after flight arrival</span>
            </li>
            <li>
              <i class="fa-solid fa-flag-checkered" aria-hidden="true"></i>
              <span data-lang="bhs">Završava na Staroj i Glavnoj autobuskoj stanici</span>
              <span data-lang="en" style="display:none">Ends at Old and Main Bus Station</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span data-lang="bhs">Karte se kupuju u autobusu</span>
              <span data-lang="en" style="display:none">Tickets are purchased on the bus</span>
            </li>
          </ul>
        </div>

        <!-- Taxi — arrival -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-taxi"></i>
            </div>
            <h3>
              <span data-lang="bhs">Taksi</span>
              <span data-lang="en" style="display:none">Taxi</span>
            </h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span data-lang="bhs">Vrijeme vožnje: 30–35 min</span>
              <span data-lang="en" style="display:none">Travel time: 30–35 min</span>
            </li>
            <li>
              <i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i>
              <span data-lang="bhs">Cijena: ~40–60 KM</span>
              <span data-lang="en" style="display:none">Price: ~40–60 KM</span>
            </li>
            <li>
              <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
              <span data-lang="bhs">Dostupno ispred terminala aerodroma</span>
              <span data-lang="en" style="display:none">Available in front of the airport terminal</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span data-lang="bhs">Dogovorite cijenu prije ulaska u vozilo</span>
              <span data-lang="en" style="display:none">Agree on the fare before getting in</span>
            </li>
          </ul>
        </div>

        <!-- Rent-a-Car — arrival -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-car"></i>
            </div>
            <h3>Rent-a-car</h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span data-lang="bhs">Vrijeme vožnje do centra: 30–35 min</span>
              <span data-lang="en" style="display:none">Drive time to center: 30–35 min</span>
            </li>
            <li>
              <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
              <span data-lang="bhs">Šalteri u zgradi aerodroma</span>
              <span data-lang="en" style="display:none">Counters in the airport building</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span data-lang="bhs">Preporučuje se unaprijed rezervisati online</span>
              <span data-lang="en" style="display:none">Advance online booking recommended</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FROM CITY TO AIRPORT -->
  <section class="section" id="city-to-airport">
    <div class="container">
      <div class="direction-heading">
        <div class="direction-heading__badge direction-heading__badge--departure">
          <i class="fa-solid fa-plane-departure" aria-hidden="true"></i>
          <span data-lang="bhs">Odlazak</span>
          <span data-lang="en" style="display:none">Departure</span>
        </div>
        <h2 class="section__title airport-section-title">
          <span data-lang="bhs">Od grada do aerodroma</span>
          <span data-lang="en" style="display:none">From the city to the airport</span>
        </h2>
        <p class="direction-heading__subtitle">
          <span data-lang="bhs">Putujete iz Banje Luke i trebate doći do aerodroma BNX.</span>
          <span data-lang="en" style="display:none">You're leaving Banja Luka and need to get to BNX Airport.</span>
        </p>
      </div>

      <div class="transport-options-grid">
        <!-- Shuttle Bus — departure -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-bus"></i>
            </div>
            <h3>
              <span data-lang="bhs">Shuttle autobus (Smiljić)</span>
              <span data-lang="en" style="display:none">Shuttle bus (Smiljić)</span>
            </h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span data-lang="bhs">Vrijeme vožnje: 30–45 min</span>
              <span data-lang="en" style="display:none">Travel time: 30–45 min</span>
            </li>
            <li>
              <i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i>
              <span data-lang="bhs">Cijena: ~10 KM (jedna vožnja)</span>
              <span data-lang="en" style="display:none">Price: ~10 KM (one way)</span>
            </li>
            <li>
              <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
              <span data-lang="bhs">Polazi od Stare i Glavne autobuske stanice</span>
              <span data-lang="en" style="display:none">Departs from Old and Main Bus Station</span>
            </li>
            <li>
              <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
              <span data-lang="bhs">Dođite barem 15 min prije polaska autobusa</span>
              <span data-lang="en" style="display:none">Arrive at least 15 min before bus departure</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span data-lang="bhs">Karte se kupuju u autobusu</span>
              <span data-lang="en" style="display:none">Tickets are purchased on the bus</span>
            </li>
          </ul>
        </div>

        <!-- Taxi — departure -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-taxi"></i>
            </div>
            <h3>
              <span data-lang="bhs">Taksi</span>
              <span data-lang="en" style="display:none">Taxi</span>
            </h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span data-lang="bhs">Vrijeme vožnje: 30–35 min</span>
              <span data-lang="en" style="display:none">Travel time: 30–35 min</span>
            </li>
            <li>
              <i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i>
              <span data-lang="bhs">Cijena: ~40–60 KM</span>
              <span data-lang="en" style="display:none">Price: ~40–60 KM</span>
            </li>
            <li>
              <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
              <span data-lang="bhs">Preuzimanje na vašoj adresi u gradu</span>
              <span data-lang="en" style="display:none">Pickup from your address in the city</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span data-lang="bhs">Preporučujemo da naručite unaprijed ili koristite aplikaciju</span>
              <span data-lang="en" style="display:none">We recommend booking in advance or using an app</span>
            </li>
          </ul>
        </div>

        <!-- Own car — departure -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-car"></i>
            </div>
            <h3>
              <span data-lang="bhs">Sopstveni automobil</span>
              <span data-lang="en" style="display:none">Own car</span>
            </h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span data-lang="bhs">Vrijeme vožnje: 30–35 min</span>
              <span data-lang="en" style="display:none">Drive time: 30–35 min</span>
            </li>
            <li>
              <i class="fa-solid fa-square-parking" aria-hidden="true"></i>
              <span data-lang="bhs">Parking na aerodromu: od 3 KM/sat</span>
              <span data-lang="en" style="display:none">Airport parking: from 3 KM/hour</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span data-lang="bhs">Pogledajte <a href="#airport-parking">detalje o parkingu</a> ispod</span>
              <span data-lang="en" style="display:none">See <a href="#airport-parking">parking details</a> below</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="airport-tip" style="margin-top: var(--space-5);">
        <i class="fa-solid fa-lightbulb" aria-hidden="true"></i>
        <p>
          <span data-lang="bhs">
            <strong>Savjet:</strong> Mnogi hoteli u Banjoj Luci mogu organizovati transfer
            do aerodroma za goste. Raspitajte se na recepciji prilikom prijave.
          </span>
          <span data-lang="en" style="display:none">
            <strong>Tip:</strong> Many hotels in Banja Luka can arrange airport transfers
            for guests. Ask at reception during check-in.
          </span>
        </p>
      </div>
    </div>
  </section>

  <!-- Shuttle Bus + Map -->
  <section class="section section--wide" id="airport">
    <div class="container">
      <h2 class="section__title airport-section-title" id="airport-shuttle-title">
        <span data-lang="bhs">Aerodromski shuttle autobus</span>
        <span data-lang="en" style="display:none">Airport Shuttle Bus</span>
      </h2>
      <AirportMap />
    </div>
  </section>

  <!-- Airport Parking -->
  <section class="section" id="airport-parking">
    <div class="container">
      <h2 class="section__title airport-section-title">
        <span data-lang="bhs">Parking na aerodromu</span>
        <span data-lang="en" style="display:none">Airport Parking</span>
      </h2>
      <div class="airport-content-block">
        <p>
          <span data-lang="bhs">
            Aerodrom Banja Luka koristi automatizirani sistem naplate parkinga sa prepoznavanjem
            registarskih tablica. Plaćanje je moguće putem SMS-a, na terminalu za naplatu u
            zgradi aerodroma, ili putem <a href="#goparking">GoParking mobilne aplikacije</a>.
          </span>
          <span data-lang="en" style="display:none">
            Banja Luka Airport uses an automated parking payment system with license plate
            recognition. Payment is available via SMS, at the payment terminal inside the
            airport building, or through the <a href="#goparking">GoParking mobile app</a>.
          </span>
        </p>

        <div class="parking-prices">
          <h3 class="parking-prices__title">
            <i class="fa-solid fa-square-parking" aria-hidden="true"></i>
            <span data-lang="bhs">Cjenovnik parkinga</span>
            <span data-lang="en" style="display:none">Parking Prices</span>
          </h3>
          <div class="parking-prices__grid">
            <div class="parking-price-item">
              <span class="parking-price-item__label">
                <span data-lang="bhs">Prvi sat</span>
                <span data-lang="en" style="display:none">First hour</span>
              </span>
              <span class="parking-price-item__value">3 KM</span>
            </div>
            <div class="parking-price-item">
              <span class="parking-price-item__label">
                <span data-lang="bhs">Prvih 24 sata</span>
                <span data-lang="en" style="display:none">First 24 hours</span>
              </span>
              <span class="parking-price-item__value">5 KM</span>
            </div>
            <div class="parking-price-item">
              <span class="parking-price-item__label">
                <span data-lang="bhs">Svaki sljedeći započeti dan</span>
                <span data-lang="en" style="display:none">Each subsequent started day</span>
              </span>
              <span class="parking-price-item__value">5 KM</span>
            </div>
          </div>
        </div>

        <div class="airport-tip">
          <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
          <p>
            <span data-lang="bhs">
              Detaljan cjenovnik parking usluga dostupan je na
              <a href="https://bnx.aero/en/home/" target="_blank" rel="noopener noreferrer">službenoj stranici aerodroma</a>.
            </span>
            <span data-lang="en" style="display:none">
              A detailed parking price list is available on the
              <a href="https://bnx.aero/en/home/" target="_blank" rel="noopener noreferrer">official airport website</a>.
            </span>
          </p>
        </div>

        <div class="goparking-box" id="goparking">
          <div class="goparking-box__header">
            <i class="fa-solid fa-mobile-screen-button" aria-hidden="true"></i>
            <h3>
              <span data-lang="bhs">Platite parking putem GoParking aplikacije</span>
              <span data-lang="en" style="display:none">Pay for parking via GoParking app</span>
            </h3>
          </div>
          <p>
            <span data-lang="bhs">
              Skenirajte QR kod sa tiketa ili unesite broj karte, izaberite način plaćanja
              (SMS ili bankovna kartica) – jednostavno, brzo i sigurno.
            </span>
            <span data-lang="en" style="display:none">
              Scan the QR code from your ticket or enter the card number, choose payment method
              (SMS or bank card) – simple, fast and secure.
            </span>
          </p>
          <div class="goparking-box__stores">
            <a
              href="https://play.google.com/store/apps/details?id=com.goparking.airport&hl=en"
              target="_blank"
              rel="noopener noreferrer"
              class="goparking-store-badge"
            >
              <i class="fa-brands fa-google-play" aria-hidden="true"></i>
              Google Play
            </a>
            <a
              href="https://apps.apple.com/ba/app/goparking-aerodromi-rs/id6746559109"
              target="_blank"
              rel="noopener noreferrer"
              class="goparking-store-badge"
            >
              <i class="fa-brands fa-apple" aria-hidden="true"></i>
              App Store
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Continue your journey - Internal links -->
  <section class="section" id="airport-continue">
    <div class="container">
      <h2 class="section__title airport-section-title">
