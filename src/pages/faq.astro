---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import faqData from '../../public/data/transport/faq.json';

const allQuestions = faqData.categories.flatMap((cat) => cat.questions);
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allQuestions.map((q) => ({
    '@type': 'Question',
    name: q.question.bhs,
    acceptedAnswer: {
      '@type': 'Answer',
      text: q.answer.bhs,
    },
  })),
};
---

<BaseLayout
  pageKey="faq"
  title="Česta pitanja - Javni prevoz Banja Luka"
  description="Odgovori na najčešća pitanja o autobuskim linijama, kartama i javnom prevozu u Banjoj Luci."
  canonicalUrl="https://blprevoz.com/faq/"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <section class="section section--narrow" id="faq">
    <div class="container">
      <h2 class="section__title" id="faq-title">Česta pitanja</h2>
      <p class="section__subtitle" id="faq-subtitle">
        Odgovori na najčešća pitanja o javnom prevozu u Banjoj Luci
      </p>
      <FAQSection />
    </div>
  </section>
</BaseLayout>
