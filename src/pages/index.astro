---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeMap from '../components/map/HomeMap.astro';
import HomeUpdatesPreview from '../components/HomeUpdatesPreview.astro';

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl}${path.replace(/^\/+/, '')}`;
---

<BaseLayout
  pageKey="home"
  title="BL Prevoz – Linije javnog prevoza u Banjoj Luci"
  description="BLum – red vožnje, linije i mapa javnog prevoza u Banjoj Luci. Sve autobuske linije, polasci, stajališta i obavještenja o izmjenama na jednom mjestu."
  canonicalUrl="https://blprevoz.com/"
>
  <section class="hero">
    <div class="container">
      <h1 id="hero-title">BLum - BL prevoz</h1>
      <p class="hero__subtitle" id="hero-subtitle">Informacije za lakše kretanje gradom.</p>
      <p class="hero__description" id="hero-description">
        Nezavisna platforma za linije, red vožnje i obavještenja o javnom prevozu u Banjoj Luci.
      </p>
      <div class="hero__details" id="hero-details" aria-label="Ključne informacije">
        <p class="hero__detail" id="hero-detail-1">
          <i class="fas fa-map-signs" aria-hidden="true"></i>
          <span>Linije i red vožnje na jednom mjestu</span>
        </p>
        <p class="hero__detail" id="hero-detail-2">
          <i class="fas fa-circle-info" aria-hidden="true"></i>
          <span>Ažurne informacije i korisni alati za kretanje gradom</span>
        </p>
      </div>
      <div class="hero__actions">
        <a href={withBase('lines/#timetable')} class="btn btn--primary btn--lg" id="hero-btn-timetables">
          <i class="fas fa-clock" aria-hidden="true"></i>
          <span class="btn__label">Red vožnje</span>
        </a>
        <a href={withBase('airport/')} class="btn btn--secondary btn--lg" id="hero-btn-airport">
          <i class="fas fa-plane-departure" aria-hidden="true"></i>
          <span class="btn__label">Transfer do aerodroma</span>
        </a>
      </div>
    </div>
  </section>

  <HomeMap />

  <HomeUpdatesPreview />
</BaseLayout>
