---
import BaseLayout from '../layouts/BaseLayout.astro';
import UpdatesSection from '../components/UpdatesSection.astro';
---

<BaseLayout
  pageKey="updates"
  title="Obavještenja – Izmjene linija i reda vožnje Banja Luka"
  description="Najnovija obavještenja o izmjenama autobuskih linija, reda vožnje i radovima na javnom prevozu u Banjoj Luci."
  canonicalUrl="https://blprevoz.com/updates/"
>
  <section class="section section--narrow" id="updates">
    <div class="container">
      <h2 class="section__title" id="updates-title">Obavještenja</h2>
      <p class="section__subtitle" id="updates-subtitle">
        Obavještenja o promjenama u prevozu, zatvaranjima ulica i izmjenama reda vožnje
      </p>
      <UpdatesSection />
    </div>
  </section>
</BaseLayout>
