---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getLineAlternatePaths,
  getLineDetailPath,
  getLineDetailUrl,
  getPagePath,
  getSwitchLocale,
  type Locale,
} from '../../lib/site-config';
import routeData from '../../../public/data/transport/routes/urban_bus_routes.json';
import timetableData from '../../../public/data/transport/timetables/urban_timetables.json';
import '../../styles/pages/_line-styles.scss';
import '../../styles/pages/_line-detail.scss';
import type { Line } from '../../types/lines';
import { getCompanyClass, getShortOperatorName } from '../../lib/lineHelpers';
import {
  compareDepartureNotes,
  getUniqueSortedDepartures,
  getUniqueSortedDeparturesFromParsed,
  parseTimeToMinutes,
  sortDeparturesAscending,
  type TimetableDeparture,
} from '../../lib/timetable-departures';
import type { NoteDescription, TimetableFile } from '../../types/timetable';

type DayKey = 'weekday' | 'saturday' | 'sunday';

type RouteDirectionData = {
  route?: string;
  stops?: string[];
};

type RouteLineData = {
  route?: string;
  directions?: Record<string, RouteDirectionData>;
};

interface StationTimetable {
  name: string;
  weekday: HourlyDepartures;
  saturday: HourlyDepartures;
  sunday: HourlyDepartures;
  hasWeekday: boolean;
  hasSaturday: boolean;
  hasSunday: boolean;
}

interface TimetableMinute {
  minute: string;
  note: string | null;
}

type HourlyDepartures = Record<string, TimetableMinute[]>;

interface DirectionPanel {
  id: 'a' | 'b';
  order: number;
  labelBhs: string;
  labelEn: string;
  routeBhs: string;
  routeEn: string;
  stops: string[];
  tables: StationTimetable[];
  hasTimetable: boolean;
  dayAvailability: Record<DayKey, boolean>;
  defaultDay: DayKey;
}

const dayTabs: { key: DayKey; bhs: string; en: string }[] = [
  { key: 'weekday', bhs: 'Radni dan', en: 'Weekday' },
  { key: 'saturday', bhs: 'Subota', en: 'Saturday' },
  { key: 'sunday', bhs: 'Nedjelja / Praznik', en: 'Sunday / Holiday' },
];

interface Props {
  locale: Locale;
  originalLineId: string;
  line: Line;
  companyName: string;
}

const { locale, originalLineId, line, companyName } = Astro.props;

const lastItem = <T,>(items: T[]): T | null => (items.length > 0 ? items[items.length - 1] : null);

const sortDirectionKeys = (a: string, b: string): number => {
  const numA = Number.parseInt(a, 10);
  const numB = Number.parseInt(b, 10);

  if (!Number.isNaN(numA) && !Number.isNaN(numB)) {
    return numA - numB;
  }

  return a.localeCompare(b);
};

const formatRouteLabel = (label: string | null | undefined): string =>
  (label ?? '').replace(/\s*-\s*/g, ' \u2192 ').trim();

const timetables = (timetableData as TimetableFile).urban;
const entry = timetables.find((t) => t.lineId === originalLineId);
const noteDescriptions = entry?.noteDescriptions ?? {};

const routes = routeData as Record<string, RouteLineData>;
const routeEntry =
  routes[originalLineId] ?? routes[originalLineId.toUpperCase()] ?? routes[originalLineId.toLowerCase()] ?? null;
const routeDirections = Object.entries(routeEntry?.directions ?? {}).sort(([keyA], [keyB]) =>
  sortDirectionKeys(keyA, keyB),
);
const routeDirectionA = routeDirections[0]?.[1] ?? null;
const routeDirectionB = routeDirections[1]?.[1] ?? null;

const nameBhs = typeof line.lineName === 'object' ? line.lineName.bhs : String(line.lineName);
const nameEn = typeof line.lineName === 'object' ? line.lineName.en : String(line.lineName);

const dirBhsA = entry?.directions?.bhs?.[0] ?? nameBhs;
const dirEnA = entry?.directions?.en?.[0] ?? nameEn;
const dirBhsB = entry?.directions?.bhs?.[1] ?? null;
const dirEnB = entry?.directions?.en?.[1] ?? null;

const companyClass = getCompanyClass(companyName);
const shortOperator = getShortOperatorName(companyName);

const sortTimesAscending = (times: string[]): string[] =>
  [...times].sort((a, b) => {
    const diff = parseTimeToMinutes(a) - parseTimeToMinutes(b);
    return diff !== 0 ? diff : a.localeCompare(b);
  });

const groupByHour = (departures: TimetableDeparture[]): HourlyDepartures => {
  const grouped: HourlyDepartures = {};

  for (const departure of sortDeparturesAscending(departures)) {
    const [rawHour = '', rawMinute = ''] = departure.time.split(':');
    const hour = rawHour.padStart(2, '0');
    const minute = rawMinute.padStart(2, '0');

    if (!grouped[hour]) {
      grouped[hour] = [];
    }
    grouped[hour].push({ minute, note: departure.note });
  }

  return grouped;
};

const buildStationTimetables = (directionIndex: number): StationTimetable[] =>
  (entry?.stations ?? []).map((station) => {
    const weekdayDepartures = getUniqueSortedDepartures(station.times.weekday?.[directionIndex] ?? []);
    const saturdayDepartures = getUniqueSortedDepartures(station.times.saturday?.[directionIndex] ?? []);
    const sundayDepartures = getUniqueSortedDepartures(station.times.sunday?.[directionIndex] ?? []);

    return {
      name: typeof station.name === 'object' ? station.name.bhs : station.name,
      weekday: groupByHour(weekdayDepartures),
      saturday: groupByHour(saturdayDepartures),
      sunday: groupByHour(sundayDepartures),
      hasWeekday: weekdayDepartures.length > 0,
      hasSaturday: saturdayDepartures.length > 0,
      hasSunday: sundayDepartures.length > 0,
    };
  });

const dirATables = buildStationTimetables(0);
const dirBTables = buildStationTimetables(1);

const hasDirA = dirATables.some((station) => station.hasWeekday || station.hasSaturday || station.hasSunday);
const hasDirB = dirBTables.some((station) => station.hasWeekday || station.hasSaturday || station.hasSunday);

const timetableStops =
  entry?.stations?.map((station) => (typeof station.name === 'object' ? station.name.bhs : station.name)) ?? [];

const routeStopsA = (routeDirectionA?.stops ?? []).filter(
  (stop): stop is string => typeof stop === 'string' && stop.trim().length > 0,
);
const routeStopsB = (routeDirectionB?.stops ?? []).filter(
  (stop): stop is string => typeof stop === 'string' && stop.trim().length > 0,
);

const directionAStops = routeStopsA.length > 0 ? routeStopsA : timetableStops;
const directionBStops = routeStopsB.length > 0 ? routeStopsB : hasDirB ? [...directionAStops].reverse() : [];

const routeStartA = directionAStops[0] ?? null;
const routeEndA = lastItem(directionAStops);

const routeSummaryBhs = routeStartA && routeEndA ? `${routeStartA} \u2192 ${routeEndA}` : formatRouteLabel(dirBhsA);
const routeSummaryEn = formatRouteLabel(dirEnA);

const flattenGroupedTimes = (grouped: HourlyDepartures): TimetableDeparture[] =>
  sortDeparturesAscending(
    Object.entries(grouped).flatMap(([hour, minutes]) =>
      minutes.map(({ minute, note }) => ({
        time: `${hour.padStart(2, '0')}:${minute.padStart(2, '0')}`,
        note,
      })),
    ),
  );

const firstStationWithData =
  dirATables.find((station) => station.hasWeekday || station.hasSaturday || station.hasSunday) ?? null;

const allFirstStationTimes = firstStationWithData
  ? sortTimesAscending([
      ...flattenGroupedTimes(firstStationWithData.weekday).map(({ time }) => time),
      ...flattenGroupedTimes(firstStationWithData.saturday).map(({ time }) => time),
      ...flattenGroupedTimes(firstStationWithData.sunday).map(({ time }) => time),
    ])
  : [];

const firstDeparture = allFirstStationTimes[0] ?? null;
const lastDeparture = lastItem(allFirstStationTimes);

const compareNumericStrings = (a: string, b: string): number => {
  const parsedA = Number.parseInt(a, 10);
  const parsedB = Number.parseInt(b, 10);

  if (Number.isNaN(parsedA) || Number.isNaN(parsedB)) {
    return a.localeCompare(b);
  }

  return parsedA - parsedB;
};

const getSortedHourEntries = (grouped: HourlyDepartures): [string, TimetableMinute[]][] =>
  Object.entries(grouped).sort(([hourA], [hourB]) => compareNumericStrings(hourA, hourB));

const mergeDayDepartures = (tables: StationTimetable[], day: DayKey): HourlyDepartures => {
  const mergedDepartures: TimetableDeparture[] = [];

  tables.forEach((station) => {
    Object.entries(station[day]).forEach(([hour, minutes]) => {
      minutes.forEach(({ minute, note }) => {
        mergedDepartures.push({ time: `${hour.padStart(2, '0')}:${minute.padStart(2, '0')}`, note });
      });
    });
  });

  return groupByHour(getUniqueSortedDeparturesFromParsed(mergedDepartures));
};

const getUsedDepartureNotes = (grouped: HourlyDepartures): string[] =>
  Array.from(
    new Set(
      Object.values(grouped).flatMap((minutes) =>
        minutes
          .map((item) => item.note)
          .filter((note): note is string => typeof note === 'string' && note.trim().length > 0),
      ),
    ),
  ).sort();

const getNoteDescription = (note: string): NoteDescription => ({
  bhs: noteDescriptions[note]?.bhs ?? `Napomena (${note})`,
  en: noteDescriptions[note]?.en ?? `Note (${note})`,
});

const hasDayData = (tables: StationTimetable[], day: DayKey): boolean =>
  tables.some((station) => Object.keys(station[day]).length > 0);

const getDefaultDay = (dayAvailability: Record<DayKey, boolean>): DayKey => {
  if (dayAvailability.weekday) return 'weekday';
  if (dayAvailability.saturday) return 'saturday';
  return 'sunday';
};

const directionPanels: DirectionPanel[] = [];

if (hasDirA || directionAStops.length > 0) {
  const dayAvailability = {
    weekday: hasDayData(dirATables, 'weekday'),
    saturday: hasDayData(dirATables, 'saturday'),
    sunday: hasDayData(dirATables, 'sunday'),
  };

  directionPanels.push({
    id: 'a',
    order: 1,
    labelBhs: dirBhsA,
    labelEn: dirEnA,
    routeBhs: formatRouteLabel(routeDirectionA?.route ?? dirBhsA),
    routeEn: formatRouteLabel(dirEnA),
    stops: directionAStops,
    tables: dirATables,
    hasTimetable: hasDirA,
    dayAvailability,
    defaultDay: getDefaultDay(dayAvailability),
  });
}

if ((hasDirB || directionBStops.length > 0) && dirBhsB) {
  const dayAvailability = {
    weekday: hasDayData(dirBTables, 'weekday'),
    saturday: hasDayData(dirBTables, 'saturday'),
    sunday: hasDayData(dirBTables, 'sunday'),
  };

  directionPanels.push({
    id: 'b',
    order: 2,
    labelBhs: dirBhsB,
    labelEn: dirEnB ?? dirBhsB,
    routeBhs: formatRouteLabel(routeDirectionB?.route ?? dirBhsB),
    routeEn: formatRouteLabel(dirEnB ?? dirBhsB),
    stops: directionBStops,
    tables: dirBTables,
    hasTimetable: hasDirB,
    dayAvailability,
    defaultDay: getDefaultDay(dayAvailability),
  });
}

const allStopsForSchema = Array.from(new Set([...directionAStops, ...directionBStops, ...timetableStops])).filter(
  (name) => name.trim().length > 0,
);

const canonicalPath = getLineDetailPath(locale, originalLineId);
const canonicalUrl = getLineDetailUrl(locale, originalLineId);
const alternatePaths = getLineAlternatePaths(originalLineId);
const pageTitle =
  locale === 'en'
    ? `Line ${originalLineId} - ${routeSummaryEn} | Banja Luka Timetable`
    : `Linija ${originalLineId} - ${routeSummaryBhs} | Red voznje Banja Luka`;
const metaDesc =
  locale === 'en'
    ? `Timetable for bus line ${originalLineId} (${routeSummaryEn}) in Banja Luka. Weekday, Saturday, and Sunday departures with route stop lists by direction.`
    : `Red voznje za autobusku liniju ${originalLineId} (${routeSummaryBhs}) u Banjoj Luci. Polasci radnim danom, subotom i nedjeljom i lista stajalista po smjerovima.`;

const lineSchema = {
  '@context': 'https://schema.org',
  '@type': 'BusRoute',
  name: locale === 'en' ? `Bus line ${originalLineId} - ${routeSummaryEn}` : `Autobuska linija ${originalLineId} - ${routeSummaryBhs}`,
  alternateName: locale === 'en' ? `Autobuska linija ${originalLineId} - ${routeSummaryBhs}` : `Bus line ${originalLineId} - ${routeSummaryEn}`,
  provider: { '@type': 'Organization', name: companyName },
  ...(allStopsForSchema.length > 0 && {
    hasPart: allStopsForSchema.map((name) => ({
      '@type': 'BusStop',
      name,
      address: { '@type': 'PostalAddress', addressLocality: 'Banja Luka', addressCountry: 'BA' },
    })),
  }),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'BL Prevoz', item: locale === 'en' ? 'https://blprevoz.com/en/' : 'https://blprevoz.com/' },
    { '@type': 'ListItem', position: 2, name: locale === 'en' ? 'Lines' : 'Linije', item: new URL(getPagePath('lines', locale), 'https://blprevoz.com/').toString() },
    { '@type': 'ListItem', position: 3, name: locale === 'en' ? `Line ${originalLineId}` : `Linija ${originalLineId}`, item: canonicalUrl },
  ],
};
---

<BaseLayout
  pageKey="lines"
  locale={locale}
  title={pageTitle}
  description={metaDesc}
  canonicalPath={canonicalPath}
  alternatePaths={alternatePaths}
  switchLanguagePath={getLineDetailPath(getSwitchLocale(locale), originalLineId)}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(lineSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="section section--narrow" id="line-detail">
    <div class="container ldp-page">
      <nav class="ldp-breadcrumb" aria-label={locale === 'en' ? 'Navigation' : 'Navigacija'}>
        <a href={getPagePath('lines', locale)}>
          <i class="fas fa-arrow-left" aria-hidden="true"></i>
          <span data-lang="bhs">Sve linije</span>
          <span data-lang="en" style="display:none">All lines</span>
        </a>
      </nav>

      <section class="ldp-section" id="line-overview" aria-labelledby="line-overview-title">
        <div class="ldp-section-heading">
          <h2 class="ldp-section-title" id="line-overview-title">
            <span data-lang="bhs">Pregled linije</span>
            <span data-lang="en" style="display:none">Line Overview</span>
          </h2>
        </div>

        <article class:list={['ldp-overview-card', 'line-card', companyClass]}>
          <div class="ldp-overview-card__head">
            <div class="line-card__identity">
              <span class="badge badge--line-number">{originalLineId}</span>
              <div class="ldp-overview-card__title-wrap">
                <h1 class="ldp-overview-card__title">
                  <span data-lang="bhs">{nameBhs}</span>
                  <span data-lang="en" style="display:none">{nameEn}</span>
                </h1>
                <p class="ldp-overview-card__route">
                  <span data-lang="bhs">{routeSummaryBhs}</span>
                  <span data-lang="en" style="display:none">{routeSummaryEn}</span>
                </p>
              </div>
            </div>

            <div class="line-card__badges">
              {line.group && (
                <span class="badge badge--group">
                  <span data-lang="bhs">Grupa </span>
                  <span data-lang="en" style="display:none">Group</span>
                  {' '}{line.group}
                </span>
              )}
              {line.wheelchair_accessible ? (
                <span
                  class="badge badge--accessible"
                  title="Pristupačno za invalidska kolica / Wheelchair accessible"
                >
                  <i class="fas fa-wheelchair" aria-hidden="true"></i>
                </span>
              ) : (
                <span class="badge badge--not-accessible" title="Nije pristupačno / Not accessible">
                  <i class="fas fa-wheelchair" aria-hidden="true"></i>
                </span>
              )}
            </div>
          </div>

          <div class="ldp-overview-grid" aria-label="Line summary metrics">
            <article class="ldp-overview-metric">
              <p class="ldp-overview-metric__label">
                <span data-lang="bhs">Prevoznik</span>
                <span data-lang="en" style="display:none">Operator</span>
              </p>
              <p class="ldp-overview-metric__value">{shortOperator}</p>
            </article>

            <article class="ldp-overview-metric">
              <p class="ldp-overview-metric__label">
                <span data-lang="bhs">Broj stajališta</span>
                <span data-lang="en" style="display:none">Stops</span>
              </p>
              <p class="ldp-overview-metric__value">
                {line.no_stops ?? (directionAStops.length > 0 ? directionAStops.length : 'N/A')}
              </p>
            </article>

            <article class="ldp-overview-metric">
              <p class="ldp-overview-metric__label">
                <span data-lang="bhs">Trajanje vožnje</span>
                <span data-lang="en" style="display:none">Trip duration</span>
              </p>
              <p class="ldp-overview-metric__value">
                {line.min_duration ? `${line.min_duration} min` : 'N/A'}
              </p>
            </article>

            <article class="ldp-overview-metric">
              <p class="ldp-overview-metric__label">
                <span data-lang="bhs">Prvi polazak</span>
                <span data-lang="en" style="display:none">First departure</span>
              </p>
              <p class="ldp-overview-metric__value">{firstDeparture ?? '--:--'}</p>
            </article>

            <article class="ldp-overview-metric">
              <p class="ldp-overview-metric__label">
                <span data-lang="bhs">Zadnji polazak</span>
                <span data-lang="en" style="display:none">Last departure</span>
              </p>
              <p class="ldp-overview-metric__value">{lastDeparture ?? '--:--'}</p>
            </article>

            <article class="ldp-overview-metric">
              <p class="ldp-overview-metric__label">
                <span data-lang="bhs">Pristupačnost</span>
                <span data-lang="en" style="display:none">Accessibility</span>
              </p>
              <p
                class:list={[
                  'ldp-overview-metric__value',
                  'ldp-overview-metric__value--status',
                  line.wheelchair_accessible ? 'is-accessible' : 'is-not-accessible',
                ]}
              >
                <i class:list={['fas', line.wheelchair_accessible ? 'fa-check-circle' : 'fa-times-circle']} aria-hidden="true"></i>
                <span data-lang="bhs">{line.wheelchair_accessible ? 'Pristupačno' : 'Nije pristupačno'}</span>
                <span data-lang="en" style="display:none">{line.wheelchair_accessible ? 'Accessible' : 'Not accessible'}</span>
              </p>
            </article>
          </div>

          {line.pdf_url && (
            <div class="ldp-overview-actions">
              <a href={line.pdf_url} target="_blank" rel="noopener noreferrer" class="btn--link pdf-btn">
                <i class="fas fa-file-pdf" aria-hidden="true"></i>
                <span data-lang="bhs">Zvanični red vožnje (PDF)</span>
                <span data-lang="en" style="display:none">Official timetable (PDF)</span>
              </a>
            </div>
          )}
        </article>
      </section>

      <section class="ldp-section" id="line-timetable" aria-labelledby="line-timetable-title">
        <div class="ldp-section-heading">
          <h2 class="ldp-section-title" id="line-timetable-title">
            <span data-lang="bhs">Red vožnje</span>
            <span data-lang="en" style="display:none">Timetable</span>
          </h2>
          <p class="ldp-section-subtitle">
            <span data-lang="bhs">Pregled polazaka po smjeru i danu, grupisano po satima i minutama.</span>
            <span data-lang="en" style="display:none">Departures by direction and day, grouped by hours and minutes.</span>
          </p>
        </div>

        {directionPanels.length > 0 ? (
          <div class="ldp-timetable-shell">
            {directionPanels.length > 1 && (
              <div class="ldp-direction-tabs" role="tablist" aria-label="Smjerovi vožnje / Directions">
                {directionPanels.map((direction, index) => (
                  <button
                    class:list={['ldp-direction-tab', index === 0 && 'is-active']}
                    type="button"
                    role="tab"
                    id={`direction-tab-${direction.id}`}
                    aria-controls={`direction-panel-${direction.id}`}
                    aria-selected={index === 0 ? 'true' : 'false'}
                    data-direction-target={direction.id}
                  >
                    <span class="ldp-direction-tab__label">
                      <span data-lang="bhs">Smjer {direction.order}</span>
                      <span data-lang="en" style="display:none">Direction {direction.order}</span>
                    </span>
                    <span class="ldp-direction-tab__route">
                      <span data-lang="bhs">{direction.routeBhs}</span>
                      <span data-lang="en" style="display:none">{direction.routeEn}</span>
                    </span>
                  </button>
                ))}
              </div>
            )}

            {directionPanels.map((direction, index) => (
              <article
                class:list={['ldp-direction-panel', index === 0 && 'is-active']}
                id={`direction-panel-${direction.id}`}
                role="tabpanel"
                aria-labelledby={`direction-tab-${direction.id}`}
                data-direction-panel={direction.id}
                hidden={index !== 0}
              >
                <header class="ldp-direction-panel__head">
                  <h3>
                    <span data-lang="bhs">{direction.labelBhs}</span>
                    <span data-lang="en" style="display:none">{direction.labelEn}</span>
                  </h3>
                  <p>
                    <span data-lang="bhs">Smjer {direction.order}</span>
                    <span data-lang="en" style="display:none">Direction {direction.order}</span>
                  </p>
                </header>

                {direction.hasTimetable ? (
                  <>
                    <div class="ldp-day-tabs" role="tablist" aria-label="Tip dana / Day type">
                      {dayTabs.map((day) => {
                        const dayAvailable = direction.dayAvailability[day.key];
                        const isDefaultDay = dayAvailable && direction.defaultDay === day.key;
                        const noServiceHint = `${day.bhs}: linija ne saobraća / ${day.en}: line does not operate`;

                        return (
                          <button
                            class:list={['ldp-day-tab', isDefaultDay && 'is-active', !dayAvailable && 'is-unavailable']}
                            type="button"
                            role="tab"
                            data-day-target={day.key}
                            data-day-available={dayAvailable ? 'true' : 'false'}
                            aria-selected={isDefaultDay ? 'true' : 'false'}
                            title={!dayAvailable ? noServiceHint : undefined}
                            aria-label={!dayAvailable ? noServiceHint : undefined}
                          >
                            <span data-lang="bhs">{day.bhs}</span>
                            <span data-lang="en" style="display:none">{day.en}</span>
                          </button>
                        );
                      })}
                    </div>

                    <div class="ldp-day-panels">
                      {dayTabs.map((day) => {
                        const dayAvailable = direction.dayAvailability[day.key];
                        const isDefaultDay = dayAvailable && direction.defaultDay === day.key;
                        const mergedDayDepartures = mergeDayDepartures(direction.tables, day.key);
                        const hasMergedDepartures = Object.keys(mergedDayDepartures).length > 0;
                        const dayUsedNotes = getUsedDepartureNotes(mergedDayDepartures);

                        return (
                          <div
                            class:list={['ldp-day-panel', isDefaultDay && 'is-active']}
                            data-day-panel={day.key}
                            hidden={!isDefaultDay}
                          >
                            {dayAvailable && hasMergedDepartures ? (
                              <>
                                <div class="ldp-station-grid">
                                  <article class="ldp-station-card">
                                    <h4 class="ldp-station-card__title">
                                      <i class="fas fa-clock" aria-hidden="true"></i>
                                      <span data-lang="bhs">Polasci</span>
                                      <span data-lang="en" style="display:none">Departures</span>
                                    </h4>

                                    <div class="ldp-station-card__table-wrap">
                                      <table class="ldp-tt-table">
                                        <thead>
                                          <tr>
                                            <th scope="col">
                                              <span data-lang="bhs">Sat</span>
                                              <span data-lang="en" style="display:none">Hour</span>
                                            </th>
                                            <th scope="col">
                                              <span data-lang="bhs">Minute</span>
                                              <span data-lang="en" style="display:none">Minutes</span>
                                            </th>
                                          </tr>
                                        </thead>
                                        <tbody>
                                          {getSortedHourEntries(mergedDayDepartures).map(([hour, minutes]) => (
                                            <tr>
                                              <th scope="row" class="ldp-tt-table__hour">{hour.padStart(2, '0')}</th>
                                              <td>
                                                <div class="ldp-minute-list">
                                                  {[...minutes]
                                                    .sort((a, b) => {
                                                      const minuteDiff = compareNumericStrings(a.minute, b.minute);
                                                      if (minuteDiff !== 0) {
                                                        return minuteDiff;
                                                      }
                                                      return compareDepartureNotes(a.note, b.note);
                                                    })
                                                    .map(({ minute, note }) => (
                                                      <span class="ldp-minute-pill">
                                                        {minute.padStart(2, '0')}
                                                        {note && <sup class="time-note">{note}</sup>}
                                                      </span>
                                                    ))}
                                                </div>
                                              </td>
                                            </tr>
                                          ))}
                                        </tbody>
                                      </table>
                                    </div>
                                  </article>
                                </div>
                                {dayUsedNotes.length > 0 && (
                                  <div class="timetable-note-descriptions">
                                    {dayUsedNotes.map((note) => {
                                      const description = getNoteDescription(note);
                                      return (
                                        <p>
                                          <sup class="time-note time-note--legend">{note}</sup>
                                          <span data-lang="bhs">{description.bhs}</span>
                                          <span data-lang="en" style="display:none">{description.en}</span>
                                        </p>
                                      );
                                    })}
                                  </div>
                                )}
                              </>
                            ) : (
                              <div class="no-service-message ldp-no-service-message" role="status">
                                <i class="fas fa-ban" aria-hidden="true"></i>
                                <strong>
                                  <span data-lang="bhs">Linija ne saobraća ovaj dan</span>
                                  <span data-lang="en" style="display:none">Line does not operate on this day</span>
                                </strong>
                                <p>
                                  <span data-lang="bhs">Izaberite drugi dan za prikaz dostupnih polazaka.</span>
                                  <span data-lang="en" style="display:none">Choose another day to see available departures.</span>
                                </p>
                              </div>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  </>
                ) : (
                  <p class="ldp-empty">
                    <span data-lang="bhs">Nema dostupnih podataka o polascima za ovaj smjer.</span>
                    <span data-lang="en" style="display:none">No departure data available for this direction.</span>
                  </p>
                )}
              </article>
            ))}
          </div>
        ) : (
          <p class="ldp-empty">
            <span data-lang="bhs">Za ovu liniju trenutno nema podataka o redu vožnje.</span>
            <span data-lang="en" style="display:none">No timetable data is currently available for this line.</span>
          </p>
        )}
      </section>

      <section class="ldp-section" id="line-stops" aria-labelledby="line-stops-title">
        <div class="ldp-section-heading">
          <h2 class="ldp-section-title" id="line-stops-title">
            <span data-lang="bhs">Stajališta na trasi</span>
            <span data-lang="en" style="display:none">Stops Along The Route</span>
          </h2>
          <p class="ldp-section-subtitle">
            <span data-lang="bhs">Prikaz stajališta po smjerovima u preglednim tabelama.</span>
            <span data-lang="en" style="display:none">Stops by direction in clear side-by-side tables.</span>
          </p>
        </div>

        <div class="ldp-stops-tables">
          {directionPanels.map((direction) => (
            <article class="ldp-stops-card card">
              <h3>
                <span data-lang="bhs">Smjer {direction.order}</span>
                <span data-lang="en" style="display:none">Direction {direction.order}</span>
              </h3>
              <p class="ldp-stops-card__route">
                <span data-lang="bhs">{direction.routeBhs}</span>
                <span data-lang="en" style="display:none">{direction.routeEn}</span>
              </p>

              {direction.stops.length > 0 ? (
                <div class="ldp-stop-table-wrap">
                  <table class="ldp-stop-table">
                    <thead>
                      <tr>
                        <th scope="col">#</th>
                        <th scope="col">
                          <span data-lang="bhs">Stajalište</span>
                          <span data-lang="en" style="display:none">Stop</span>
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      {direction.stops.map((stopName, stopIndex) => (
                        <tr>
                          <td class="ldp-stop-table__index">{String(stopIndex + 1).padStart(2, '0')}</td>
                          <td class="ldp-stop-table__name">{stopName}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ) : (
                <p class="ldp-empty">
                  <span data-lang="bhs">Podaci o stajalištima nisu dostupni za ovaj smjer.</span>
                  <span data-lang="en" style="display:none">Stop data is unavailable for this direction.</span>
                </p>
              )}
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>

  <script>
    import { initLineDetailTabs } from '../../scripts/features/lines/line-detail-tabs';
    const bootLineDetailTabs = () => initLineDetailTabs();
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootLineDetailTabs, { once: true });
    } else {
      bootLineDetailTabs();
    }
  </script>
</BaseLayout>
