---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AirportMap from '../../components/AirportMap.astro';
import {
  addHashToPath,
  getAlternatePaths,
  getLocalizedMeta,
  getPagePath,
  getSwitchLocale,
  type Locale,
} from '../../lib/site-config';
// FontAwesome brands icons (fa-google-play, fa-apple) only used on this page
import '@fortawesome/fontawesome-free/css/brands.min.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl}${path.replace(/^\/+/, '')}`;

const airportFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: locale === 'en'
    ? [
        {
          '@type': 'Question',
          name: 'How do I get from Banja Luka Airport to the city center?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Take the Smiljić shuttle bus for approximately 10 KM (30-45 minutes), or a taxi for 40-60 KM (30-35 minutes). The shuttle waits outside the terminal after each flight arrival and ends at the Old and Main Bus Station.',
          },
        },
        {
          '@type': 'Question',
          name: 'How much does the Banja Luka airport bus cost?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The Smiljić airport shuttle costs approximately 10 KM one way. Tickets are purchased on the bus.',
          },
        },
        {
          '@type': 'Question',
          name: 'How far is Banja Luka Airport from the city center?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Banja Luka Airport (BNX) is located in Mahovljani, approximately 25 km north of the city center via the E661 motorway.',
          },
        },
      ]
    : [
        {
          '@type': 'Question',
          name: 'Kako doći od aerodroma Banja Luka do centra grada?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Shuttle autobusom kompanije Smiljić za oko 10 KM (30-45 min), ili taksijem za 40-60 KM (30-35 min). Autobus čeka ispred terminala nakon svakog leta i završava na Staroj i Glavnoj autobuskoj stanici.',
          },
        },
        {
          '@type': 'Question',
          name: 'Koliko kosta shuttle autobus od aerodroma Banja Luka?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Shuttle autobus kompanije Smiljić košta oko 10 KM (jedna vožnja). Karte se kupuju u autobusu.',
          },
        },
        {
          '@type': 'Question',
          name: 'Koliko je daleko aerodrom Banja Luka od centra?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Aerodrom Banja Luka (BNX) nalazi se u Mahovljanima, oko 25 km sjeverno od centra grada, autoputem E661.',
          },
        },
      ],
};

const airportShuttleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BusTrip',
  name: locale === 'en' ? 'Banja Luka Airport Shuttle (Smiljić)' : 'Shuttle prevoz do Aerodroma Banja Luka (Smiljić)',
  description:
    locale === 'en'
      ? 'Airport shuttle bus connecting Banja Luka city center to Banja Luka International Airport (BNX). Operated by Smiljić company.'
      : 'Shuttle autobus koji povezuje centar Banje Luke sa Međunarodnim aerodromom Banja Luka (BNX). Prevoznik je kompanija Smiljić.',
  provider: {
    '@type': 'Organization',
    name: 'Smiljić',
    url: 'https://smiljiccompany.ba/avio-transferi/',
  },
  departureStop: {
    '@type': 'BusStation',
    name: locale === 'en' ? 'Old and Main Bus Station Banja Luka' : 'Stara i Glavna autobuska stanica Banja Luka',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Banja Luka',
      addressCountry: 'BA',
    },
  },
  arrivalStop: {
    '@type': 'Airport',
    name: locale === 'en' ? 'Banja Luka Airport' : 'Aerodrom Banja Luka',
    iataCode: 'BNX',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Mahovljani bb',
      addressLocality: 'Banja Luka',
      addressCountry: 'BA',
    },
  },
};
const meta = getLocalizedMeta('airport', locale);
const alternatePaths = getAlternatePaths('airport');
const linesPath = withBase(getPagePath('lines', locale));
const timetablePath = withBase(addHashToPath(getPagePath('lines', locale), 'timetable'));
const pricingPath = withBase(getPagePath('pricing', locale));
const isEnglish = locale === 'en';
const t = (bhs: string, en: string): string => (isEnglish ? en : bhs);
---

<BaseLayout
  pageKey="airport"
  locale={locale}
  title={meta.title}
  description={meta.description}
  canonicalPath={getPagePath('airport', locale)}
  alternatePaths={alternatePaths}
  switchLanguagePath={getPagePath('airport', getSwitchLocale(locale))}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(airportFaqSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(airportShuttleSchema)} />
  <!-- Airport Overview -->
  <section class="section" id="airport-overview">
    <div class="container">
      <h1 class="section__title" id="airport-title">{t('Prevoz do Aerodroma Banja Luka', 'Getting to Banja Luka Airport')}</h1>
      <p class="airport-intro" id="airport-intro">
        {isEnglish
          ? `Banja Luka International Airport (IATA: BNX) is located in Mahovljani, approximately
          25 km north of the city center. The fastest access is via the E661 motorway (Banja Luka - Gradiška).
          The airport is connected to the city by Smiljić shuttle bus, and taxi services are
          also available. Below you'll find all the information you need to plan your arrival or departure.`
          : `Međunarodni aerodrom Banja Luka (IATA: BNX) nalazi se u Mahovljanima, oko 25 km
          sjeverno od centra grada. Najbrži pristup je autoputem E661 (Banja Luka - Gradiška).
          Aerodrom je povezan sa gradom shuttle autobusom kompanije Smiljić, a dostupne su
          i taksi usluge. Ispod su sve informacije potrebne za planiranje vašeg dolaska ili odlaska.`}
      </p>

      <!-- Fast Answer Block -->
      <div class="airport-fast-answer">
        <div class="airport-fast-answer__header">
          <i class="fa-solid fa-bolt" aria-hidden="true"></i>
          <h2>{t('Kako od aerodroma do centra grada?', 'How to get from the airport to the city center?')}</h2>
        </div>
        <div class="airport-fast-answer__options">
          <div class="airport-fast-answer__option">
            <i class="fa-solid fa-bus" aria-hidden="true"></i>
            <div>
              <strong>{t('Shuttle autobus', 'Shuttle bus')}</strong>
              <span>~10 KM · 30-45 min</span>
            </div>
          </div>
          <div class="airport-fast-answer__option">
            <i class="fa-solid fa-taxi" aria-hidden="true"></i>
            <div>
              <strong>{t('Taksi', 'Taxi')}</strong>
              <span>~40-60 KM · 30-35 min</span>
            </div>
          </div>
          <div class="airport-fast-answer__option">
            <i class="fa-solid fa-car" aria-hidden="true"></i>
            <div>
              <strong>Rent-a-car</strong>
              <span>{t('Dostupno na aerodromu', 'Available at the airport')}</span>
            </div>
          </div>
        </div>
        <p class="airport-fast-answer__note">
          {isEnglish ? (
            <span>Distance from airport to city center: <strong>~25 km</strong> (E661 motorway, Mahovljani interchange)</span>
          ) : (
            <span>Udaljenost od aerodroma do centra: <strong>~25 km</strong> (autoput E661, petlja Mahovljani)</span>
          )}
        </p>
      </div>
    </div>
  </section>

  <!-- Quick Facts -->
  <section class="section airport-quickfacts" id="airport-quickfacts">
    <div class="container">
      <h2 class="section__title airport-section-title">{t('Osnovne informacije', 'Quick Facts')}</h2>
      <div class="quickfacts-grid">
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-road"></i>
          </div>
          <div class="quickfact-card__label">{t('Udaljenost', 'Distance')}</div>
          <div class="quickfact-card__value">~25 km</div>
        </div>
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-clock"></i>
          </div>
          <div class="quickfact-card__label">{t('Vrijeme vožnje', 'Travel time')}</div>
          <div class="quickfact-card__value">30-45 min</div>
        </div>
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-money-bill-wave"></i>
          </div>
          <div class="quickfact-card__label">{t('Cijena autobusa', 'Bus price')}</div>
          <div class="quickfact-card__value">~10 KM</div>
        </div>
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-building"></i>
          </div>
          <div class="quickfact-card__label">{t('Prevoznik', 'Operator')}</div>
          <div class="quickfact-card__value">Smiljić</div>
        </div>
        <div class="quickfact-card">
          <div class="quickfact-card__icon" aria-hidden="true">
            <i class="fa-solid fa-calendar-day"></i>
          </div>
          <div class="quickfact-card__label">{t('Učestalost', 'Frequency')}</div>
          <div class="quickfact-card__value">{t('Nekoliko polazaka dnevno', 'Few departures per day')}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FROM AIRPORT TO CITY -->
  <section class="section" id="airport-to-city">
    <div class="container">
      <div class="direction-heading">
        <div class="direction-heading__badge direction-heading__badge--arrival">
          <i class="fa-solid fa-plane-arrival" aria-hidden="true"></i>
          {t('Dolazak', 'Arrival')}
        </div>
        <h2 class="section__title airport-section-title">{t('Od aerodroma do grada', 'From the airport to the city')}</h2>
        <p class="direction-heading__subtitle">{t('Sletjeli ste na aerodrom BNX i trebate doći do centra Banje Luke.', "You've landed at BNX Airport and need to get to downtown Banja Luka.")}</p>
      </div>

      <div class="transport-options-grid">
        <!-- Shuttle Bus — arrival -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-bus"></i>
            </div>
            <h3>{t('Shuttle autobus (Smiljić)', 'Shuttle bus (Smiljić)')}</h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span>{t('Vrijeme vožnje: 30-45 min', 'Travel time: 30-45 min')}</span>
            </li>
            <li>
              <i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i>
              <span>{t('Cijena: ~10 KM (jedna vožnja)', 'Price: ~10 KM (one way)')}</span>
            </li>
            <li>
              <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
              <span>{t('Autobus čeka ispred terminala nakon dolaska leta', 'Bus waits in front of the terminal after flight arrival')}</span>
            </li>
            <li>
              <i class="fa-solid fa-flag-checkered" aria-hidden="true"></i>
              <span>{t('Završava na Staroj i Glavnoj autobuskoj stanici', 'Ends at Old and Main Bus Station')}</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span>{t('Karte se kupuju u autobusu', 'Tickets are purchased on the bus')}</span>
            </li>
          </ul>
        </div>

        <!-- Taxi — arrival -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-taxi"></i>
            </div>
            <h3>{t('Taksi', 'Taxi')}</h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span>{t('Vrijeme vožnje: 30-35 min', 'Travel time: 30-35 min')}</span>
            </li>
            <li>
              <i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i>
              <span>{t('Cijena: ~40-60 KM', 'Price: ~40-60 KM')}</span>
            </li>
            <li>
              <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
              <span>{t('Dostupno ispred terminala aerodroma', 'Available in front of the airport terminal')}</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span>{t('Dogovorite cijenu prije ulaska u vozilo', 'Agree on the fare before getting in')}</span>
            </li>
          </ul>
        </div>

        <!-- Rent-a-Car — arrival -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-car"></i>
            </div>
            <h3>Rent-a-car</h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span>{t('Vrijeme vožnje do centra: 30-35 min', 'Drive time to center: 30-35 min')}</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span>{t('Preporučuje se unaprijed rezervisati online', 'Advance online booking recommended')}</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FROM CITY TO AIRPORT -->
  <section class="section" id="city-to-airport">
    <div class="container">
      <div class="direction-heading">
        <div class="direction-heading__badge direction-heading__badge--departure">
          <i class="fa-solid fa-plane-departure" aria-hidden="true"></i>
          {t('Odlazak', 'Departure')}
        </div>
        <h2 class="section__title airport-section-title">{t('Od grada do aerodroma', 'From the city to the airport')}</h2>
        <p class="direction-heading__subtitle">{t('Putujete iz Banje Luke i trebate doći do aerodroma BNX.', "You're leaving Banja Luka and need to get to BNX Airport.")}</p>
      </div>

      <div class="transport-options-grid">
        <!-- Shuttle Bus — departure -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-bus"></i>
            </div>
            <h3>{t('Shuttle autobus (Smiljić)', 'Shuttle bus (Smiljić)')}</h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span>{t('Vrijeme vožnje: 30-45 min', 'Travel time: 30-45 min')}</span>
            </li>
            <li>
              <i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i>
              <span>{t('Cijena: ~10 KM (jedna vožnja)', 'Price: ~10 KM (one way)')}</span>
            </li>
            <li>
              <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
              <span>{t('Polazi od Stare i Glavne autobuske stanice', 'Departs from Old and Main Bus Station')}</span>
            </li>
            <li>
              <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
              <span>{t('Dođite barem 15 min prije polaska autobusa', 'Arrive at least 15 min before bus departure')}</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span>{t('Karte se kupuju u autobusu', 'Tickets are purchased on the bus')}</span>
            </li>
          </ul>
        </div>

        <!-- Taxi — departure -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-taxi"></i>
            </div>
            <h3>{t('Taksi', 'Taxi')}</h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span>{t('Vrijeme vožnje: 30-35 min', 'Travel time: 30-35 min')}</span>
            </li>
            <li>
              <i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i>
              <span>{t('Cijena: ~40-60 KM', 'Price: ~40-60 KM')}</span>
            </li>
            <li>
              <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
              <span>{t('Preuzimanje na vašoj adresi u gradu', 'Pickup from your address in the city')}</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              <span>{t('Preporučujemo da naručite unaprijed ili koristite aplikaciju', 'We recommend booking in advance or using an app')}</span>
            </li>
          </ul>
        </div>

        <!-- Own car — departure -->
        <div class="transport-option-card">
          <div class="transport-option-card__header">
            <div class="transport-option-card__icon" aria-hidden="true">
              <i class="fa-solid fa-car"></i>
            </div>
            <h3>{t('Sopstveni automobil', 'Own car')}</h3>
          </div>
          <ul class="transport-option-card__details">
            <li>
              <i class="fa-solid fa-clock" aria-hidden="true"></i>
              <span>{t('Vrijeme vožnje: 30-35 min', 'Drive time: 30-35 min')}</span>
            </li>
            <li>
              <i class="fa-solid fa-square-parking" aria-hidden="true"></i>
              <span>{t('Parking na aerodromu: od 3 KM/sat', 'Airport parking: from 3 KM/hour')}</span>
            </li>
            <li>
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              {isEnglish ? (
                <span>See <a href="#airport-parking">parking details</a> below</span>
              ) : (
                <span>Pogledajte <a href="#airport-parking">detalje o parkingu</a> ispod</span>
              )}
            </li>
          </ul>
        </div>
      </div>

      <div class="airport-tip" style="margin-top: var(--space-5);">
        <i class="fa-solid fa-lightbulb" aria-hidden="true"></i>
        <p>
          {isEnglish ? (
            <span><strong>Tip:</strong> Many hotels in Banja Luka can arrange airport transfers for guests. Ask at reception during check-in.</span>
          ) : (
            <span><strong>Savjet:</strong> Mnogi hoteli u Banjoj Luci mogu organizovati transfer do aerodroma za goste. Raspitajte se na recepciji prilikom prijave.</span>
          )}
        </p>
      </div>
    </div>
  </section>

  <!-- Shuttle Bus + Map -->
  <section class="section section--wide" id="airport">
    <div class="container">
      <h2 class="section__title airport-section-title" id="airport-shuttle-title">{t('Aerodromski shuttle autobus', 'Airport Shuttle Bus')}</h2>
      <AirportMap locale={locale} />
    </div>
  </section>

  <!-- Airport Parking -->
  <section class="section" id="airport-parking">
    <div class="container">
      <h2 class="section__title airport-section-title">{t('Parking na aerodromu', 'Airport Parking')}</h2>
      <div class="airport-content-block">
        <p>
          {isEnglish ? (
            <span>
              Banja Luka Airport uses an automated parking payment system with license plate
              recognition. Payment is available via SMS, at the payment terminal inside the
              airport building, or through the <a href="#goparking">GoParking mobile app</a>.
            </span>
          ) : (
            <span>
              Aerodrom Banja Luka koristi automatizovani sistem naplate parkinga sa prepoznavanjem
              registarskih tablica. Placanje je moguce putem SMS-a, na terminalu za naplatu u
              zgradi aerodroma, ili putem <a href="#goparking">GoParking mobilne aplikacije</a>.
            </span>
          )}
        </p>

        <div class="parking-prices">
          <h3 class="parking-prices__title">
            <i class="fa-solid fa-square-parking" aria-hidden="true"></i>
            {t('Cjenovnik parkinga', 'Parking Prices')}
          </h3>
          <div class="parking-prices__grid">
            <div class="parking-price-item">
              <span class="parking-price-item__label">{t('Prvi sat', 'First hour')}</span>
              <span class="parking-price-item__value">3 KM</span>
            </div>
            <div class="parking-price-item">
              <span class="parking-price-item__label">{t('Prvih 24 sata', 'First 24 hours')}</span>
              <span class="parking-price-item__value">5 KM</span>
            </div>
            <div class="parking-price-item">
              <span class="parking-price-item__label">{t('Svaki sljedeći započeti dan', 'Each subsequent started day')}</span>
              <span class="parking-price-item__value">5 KM</span>
            </div>
          </div>
        </div>

        <div class="airport-tip">
          <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
          <p>
            {isEnglish ? (
              <span>
                A detailed parking price list is available on the
                <a href="https://bnx.aero/en/home/" target="_blank" rel="noopener noreferrer"> official airport website</a>.
              </span>
            ) : (
              <span>
                Detaljan cjenovnik parking usluga dostupan je na
                <a href="https://bnx.aero/en/home/" target="_blank" rel="noopener noreferrer"> službenoj stranici aerodroma</a>.
              </span>
            )}
          </p>
        </div>

        <div class="goparking-box" id="goparking">
          <div class="goparking-box__header">
            <i class="fa-solid fa-mobile-screen-button" aria-hidden="true"></i>
            <h3>{t('Platite parking putem GoParking aplikacije', 'Pay for parking via GoParking app')}</h3>
          </div>
          <p>
            {t(
              'Skenirajte QR kod sa tiketa ili unesite broj karte, izaberite način plaćanja (SMS ili bankovna kartica) - jednostavno, brzo i sigurno.',
              'Scan the QR code from your ticket or enter the card number, choose payment method (SMS or bank card) - simple, fast and secure.',
            )}
          </p>
          <div class="goparking-box__stores">
            <a
              href="https://play.google.com/store/apps/details?id=com.goparking.airport&hl=en"
              target="_blank"
              rel="noopener noreferrer"
              class="goparking-store-badge"
            >
              <i class="fa-brands fa-google-play" aria-hidden="true"></i>
              Google Play
            </a>
            <a
              href="https://apps.apple.com/ba/app/goparking-aerodromi-rs/id6746559109"
              target="_blank"
              rel="noopener noreferrer"
              class="goparking-store-badge"
            >
              <i class="fa-brands fa-apple" aria-hidden="true"></i>
              App Store
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Continue your journey - Internal links -->
  <section class="section" id="airport-continue">
    <div class="container">
      <h2 class="section__title airport-section-title">{t('Nastavite putovanje javnim prevozom', 'Continue your journey by public transport')}</h2>
      <p class="airport-intro" style="margin-bottom: var(--space-5);">
        {t('Nakon dolaska u Banju Luku, možete nastaviti putovanje gradskim autobuskim linijama.', 'After arriving in Banja Luka, you can continue your journey using city bus lines.')}
      </p>
      <div class="airport-links-grid">
        <a href={linesPath} class="airport-link-card">
          <i class="fa-solid fa-route" aria-hidden="true"></i>
          <div>
            <strong>{t('Autobuske linije', 'Bus lines')}</strong>
            <span class="airport-link-card__desc">{t('Sve gradske linije i mapa stajališta', 'All city lines and stop maps')}</span>
          </div>
        </a>
        <a href={timetablePath} class="airport-link-card">
          <i class="fa-solid fa-clock" aria-hidden="true"></i>
          <div>
            <strong>{t('Red vožnje', 'Timetables')}</strong>
            <span class="airport-link-card__desc">{t('Polasci gradskih autobuskih linija', 'City bus line departures')}</span>
          </div>
        </a>
        <a href={pricingPath} class="airport-link-card">
          <i class="fa-solid fa-ticket" aria-hidden="true"></i>
          <div>
            <strong>{t('Cijene karata', 'Ticket prices')}</strong>
            <span class="airport-link-card__desc">{t('Cjenovnik javnog prevoza', 'Public transport pricing')}</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Useful Links -->
  <section class="section" id="airport-links">
    <div class="container">
      <h2 class="section__title airport-section-title">{t('Korisni linkovi', 'Useful Links')}</h2>
      <div class="airport-links-grid">
        <a
          href="https://bnx.aero/en/home/"
          target="_blank"
          rel="noopener noreferrer"
          class="airport-link-card"
        >
          <i class="fa-solid fa-plane" aria-hidden="true"></i>
          <div>
            <strong>{t('Aerodrom Banja Luka', 'Banja Luka Airport')}</strong>
            <span class="airport-link-card__url">bnx.aero</span>
          </div>
          <i class="fa-solid fa-arrow-up-right-from-square airport-link-card__arrow" aria-hidden="true"></i>
        </a>
        <a
          href="https://smiljiccompany.ba/avio-transferi/"
          target="_blank"
          rel="noopener noreferrer"
          class="airport-link-card"
        >
          <i class="fa-solid fa-van-shuttle" aria-hidden="true"></i>
          <div>
            <strong>{t('Smiljić - Avio transferi', 'Smiljić - Airport Transfers')}</strong>
            <span class="airport-link-card__url">smiljiccompany.ba</span>
          </div>
          <i class="fa-solid fa-arrow-up-right-from-square airport-link-card__arrow" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Last Updated -->
  <div class="container">
    <p class="airport-last-updated">
      <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
      {t('Informacije posljednji put provjerene: mart 2026.', 'Information last reviewed: March 2026.')}
    </p>
  </div>
</BaseLayout>
