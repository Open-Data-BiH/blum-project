---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getAlternatePaths, getLocalizedMeta, getPagePath, getSwitchLocale, type Locale } from '../../lib/site-config';
import faqData from '../../../public/data/transport/faq.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const allQuestions = faqData.categories.flatMap((cat) => cat.questions);
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allQuestions.map((q) => ({
    '@type': 'Question',
    name: q.question[locale],
    acceptedAnswer: {
      '@type': 'Answer',
      text: q.answer[locale],
    },
  })),
};
const meta = getLocalizedMeta('faq', locale);
const alternatePaths = getAlternatePaths('faq');
---

<BaseLayout
  pageKey="faq"
  locale={locale}
  title={meta.title}
  description={meta.description}
  canonicalPath={getPagePath('faq', locale)}
  alternatePaths={alternatePaths}
  switchLanguagePath={getPagePath('faq', getSwitchLocale(locale))}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <section class="section section--narrow" id="faq">
    <div class="container">
      <h2 class="section__title" id="faq-title">{locale === 'en' ? 'Frequently asked questions' : 'Cesta pitanja'}</h2>
      <p class="section__subtitle" id="faq-subtitle">
        {locale === 'en'
          ? 'Answers to common questions about public transport in Banja Luka'
          : 'Odgovori na najcesca pitanja o javnom prevozu u Banjoj Luci'}
      </p>
      <FAQSection />
    </div>
  </section>
</BaseLayout>
