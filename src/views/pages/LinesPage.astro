---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UrbanLinesViewer from '../../components/lines/UrbanLinesViewer.astro';
import LinesSection from '../../components/lines/LinesSection.astro';
import TimetableSection from '../../components/lines/TimetableSection.astro';
import translationsData from '../../../public/data/config/bhs_en_translations.json';
import { getAlternatePaths, getLocalizedMeta, getPagePath, getSwitchLocale, type Locale } from '../../lib/site-config';

import ownershipData from '../../../public/data/transport/routes/urban_company_ownership.json';
import timetableData from '../../../public/data/transport/timetables/urban_timetables.json';
import type { CompanyOwnership } from '../../types/lines';
import type { ProcessedLine, ScheduleStats } from '../../types/lines';
import type { TimetableFile, TimetableTime } from '../../types/timetable';
import { getCompanyClass, getShortOperatorName } from '../../lib/lineHelpers';
import { normalizeForSearch, sortLinesByID } from '../../scripts/core/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const meta = getLocalizedMeta('lines', locale);
const alternatePaths = getAlternatePaths('lines');
const translations = translationsData[locale];
const isEnglish = locale === 'en';

// ─── Helper functions (mirrors lines-ui.js, run at build time) ──────────────

// ─── Schedule stats computation ─────────────────────────────────────────────

const timetables = (timetableData as TimetableFile).urban;
const timetableMap = new Map(timetables.map((t) => [t.lineId, t]));

const getTimeString = (t: TimetableTime): string =>
  typeof t === 'string' ? t : t.time;

const computeScheduleStats = (lineId: string): ScheduleStats => {
  const entry = timetableMap.get(lineId);
  if (!entry || entry.stations.length === 0) {
    return { firstBus: null, lastBus: null, avgFrequency: null };
  }

  // Use first station, direction A (index 0), weekday schedule
  const times = entry.stations[0].times.weekday[0];
  if (!times || times.length === 0) {
    return { firstBus: null, lastBus: null, avgFrequency: null };
  }

  const timeStrings = times.map(getTimeString);
  const firstBus = timeStrings[0];
  const lastBus = timeStrings[timeStrings.length - 1];

  // Average frequency: mean gap between consecutive departures
  let avgFrequency: number | null = null;
  if (timeStrings.length >= 2) {
    const toMinutes = (hhmm: string) => {
      const [h, m] = hhmm.split(':').map(Number);
      return h * 60 + m;
    };
    let totalGap = 0;
    for (let i = 1; i < timeStrings.length; i++) {
      totalGap += toMinutes(timeStrings[i]) - toMinutes(timeStrings[i - 1]);
    }
    avgFrequency = Math.round(totalGap / (timeStrings.length - 1));
  }

  return { firstBus, lastBus, avgFrequency };
};

// ─── Build flat processed line array ────────────────────────────────────────

const data = ownershipData as CompanyOwnership;

const processedLines: ProcessedLine[] = [];

data.urban.forEach((company) => {
  company.lines.forEach((line) => {
    const nameBhs = typeof line.lineName === 'object' ? line.lineName.bhs : String(line.lineName);
    const nameEn = typeof line.lineName === 'object' ? line.lineName.en : String(line.lineName);

    processedLines.push({
      ...line,
      companyName: company.companyName,
      lineType: 'urban',
      hasMultilingualName: true,
      searchText: normalizeForSearch(
        line.lineId + ' ' + nameBhs + ' ' + nameEn + ' ' + company.companyName,
      ),
      companyClass: getCompanyClass(company.companyName),
      shortOperator: getShortOperatorName(company.companyName),
      schedule: computeScheduleStats(line.lineId),
    });
  });
});

processedLines.sort(sortLinesByID);
---

<BaseLayout
  pageKey="lines"
  locale={locale}
  title={meta.title}
  description={meta.description}
  canonicalPath={getPagePath('lines', locale)}
  alternatePaths={alternatePaths}
  switchLanguagePath={getPagePath('lines', getSwitchLocale(locale))}
>
  <!-- Urban Lines Map Section -->
  <section class="section section--wide" id="urban-lines">
    <div class="container">
      <h2 class="section__title" id="urban-lines-title">{translations.sections?.urban_lines?.title ?? (locale === 'en' ? 'Urban lines map' : 'Mapa gradskih linija')}</h2>

      <UrbanLinesViewer />

      <article class="map-context-card" aria-labelledby="map-context-title">
        <div class="map-context-card__header">
          <i class="fas fa-map-location-dot map-context-card__icon" aria-hidden="true"></i>
          <h3 class="map-context-card__title" id="map-context-title">{isEnglish ? 'Map information' : 'Informacije o mapi'}</h3>
        </div>

        {isEnglish ? (
          <div class="map-context__content">
            <p>
              This map displays public transport routes and was created by the
              <strong>Citizens' Association "<a
                href="https://www.imamoplan.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="map-context__link"
              >Uticajna Grupa - Imamo Plan</a>"</strong>
              from Serbia, founded in
              <strong>2012 by Jug Cerović, Marko Njegić and Stefan Milojević</strong>.
            </p>
            <p>
              The map is a <strong>gift to the city and its citizens</strong>, developed as a volunteer
              initiative aimed at improving access to and visibility of public transport information.
            </p>
            <div class="map-context__note">
              <strong>NOTE:</strong> Map displays are for informational purposes and are based on publicly available data, which may not always be complete or fully up to date.
            </div>
            <p>We thank the authors for their valuable contribution to the community.</p>
          </div>
        ) : (
          <div class="map-context__content">
            <p>
              Mapa prikazuje trase linija javnog prevoza i rezultat je rada
              <strong>Udruženja Građana "<a
                href="https://www.imamoplan.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="map-context__link"
              >Uticajna Grupa - Imamo Plan</a>"</strong>
              iz Srbije, koje su osnovali
              <strong>Jug Cerović, Marko Njegić i Stefan Milojević 2012. godine</strong>.
            </p>
            <p>
              Ova mapa predstavlja <strong>poklon gradu i građanima</strong>, nastala iz entuzijazma i
              volonterskog angažmana, s ciljem da se unaprijedi preglednost i dostupnost informacija o
              javnom prevozu.
            </p>
            <div class="map-context__note">
              <strong>NAPOMENA:</strong> Prikazi na mapi su informativnog karaktera i zasnovani su na javno dostupnim podacima, koji možda nisu uvijek potpuni ili u potpunosti ažurni.
            </div>
            <p>Zahvaljujemo se autorima za doprinos zajednici.</p>
          </div>
        )}
      </article>

      <details class="map-help-disclosure">
        <summary class="map-help-disclosure__summary">
          {isEnglish ? 'How to use the map' : 'Kako koristiti mapu'}
          <i class="fas fa-chevron-down" aria-hidden="true"></i>
        </summary>
        <div class="map-help-disclosure__content">
          <p class="map-help-disclosure__text" id="lines-map-note">
            {translations.sections?.lines?.mapNote}
          </p>
        </div>
      </details>
    </div>
  </section>

  <!-- Lines Section -->
  <section class="section section--wide" id="lines">
    <div class="container">
      <h2 class="section__title" id="lines-title">{translations.sections?.lines?.title ?? (locale === 'en' ? 'Lines' : 'Linije')}</h2>

      <article class="lines-info-card" aria-labelledby="lines-info-title">
        <div class="lines-info-card__header">
          <i class="fas fa-diagram-project lines-info-card__icon" aria-hidden="true"></i>
          <h3 class="lines-info-card__title" id="lines-info-title">
            <span id="lines-info-title-text">{translations.sections?.lines?.infoTitle ?? (locale === 'en' ? 'Line groups and operators' : 'Grupe linija i prevoznici')}</span>
          </h3>
        </div>

        <p class="lines-info-card__text" id="lines-info-text">
          {translations.sections?.lines?.infoText ?? (locale === 'en'
            ? 'Urban lines are organized into three groups, and each line card shows both its group and the operator responsible for that route.'
            : 'Gradske linije su organizovane u tri grupe, a svaka kartica linije prikazuje grupu i prevoznika koji odrzava tu liniju.')}
        </p>

        <div class="operator-legend operator-legend--compact">
          <div class="legend-item autoprevoz-legend">
            <span class="color-box"></span>
            <span class="operator-name">AUTOPREVOZ GS</span>
          </div>
          <div class="legend-item pavlovic-legend">
            <span class="color-box"></span>
            <span class="operator-name">PAVLOVIĆ Tours</span>
          </div>
          <div class="legend-item bocac-legend">
            <span class="color-box"></span>
            <span class="operator-name">BOČAC Tours</span>
          </div>
          <div class="legend-item aldemo-legend">
            <span class="color-box"></span>
            <span class="operator-name">ALDEMO Tours</span>
          </div>
          <div class="legend-item rale-legend">
            <span class="color-box"></span>
            <span class="operator-name">RALE Tours</span>
          </div>
        </div>

        <p class="lines-info-card__note">
          {isEnglish
            ? 'The line number badge color on each card matches the operator color shown in the legend.'
            : 'Boja oznake broja linije na kartici prati boju prevoznika iz legende.'}
        </p>
      </article>

      <LinesSection lines={processedLines} locale={locale} />
    </div>
  </section>

  <TimetableSection locale={locale} />
</BaseLayout>
