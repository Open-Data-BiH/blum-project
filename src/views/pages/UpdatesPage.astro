---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UpdatesSection from '../../components/UpdatesSection.astro';
import { getAlternatePaths, getLocalizedMeta, getPagePath, getSwitchLocale, type Locale } from '../../lib/site-config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const meta = getLocalizedMeta('updates', locale);
const alternatePaths = getAlternatePaths('updates');
---

<BaseLayout
  pageKey="updates"
  locale={locale}
  title={meta.title}
  description={meta.description}
  canonicalPath={getPagePath('updates', locale)}
  alternatePaths={alternatePaths}
  switchLanguagePath={getPagePath('updates', getSwitchLocale(locale))}
>
  <section class="section section--narrow" id="updates">
    <div class="container">
      <h2 class="section__title" id="updates-title">{locale === 'en' ? 'Updates' : 'Obavjestenja'}</h2>
      <p class="section__subtitle" id="updates-subtitle">
        {locale === 'en'
          ? 'Notices about transport changes, street closures, and timetable updates'
          : 'Obavjestenja o promjenama u prevozu, zatvaranjima ulica i izmjenama reda voznje'}
      </p>
      <UpdatesSection locale={locale} />
    </div>
  </section>
</BaseLayout>
